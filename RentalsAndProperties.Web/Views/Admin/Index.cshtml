@model List<RentalsAndProperties.Web.ViewModels.Property.PropertyDetailViewModel>
@{
    ViewData["Title"] = "Admin – Pending Approvals";
}

<div class="dashboard-page">
    <div class="dashboard-header" style="background:linear-gradient(135deg,#1e1b4b 0%,#312e81 100%);">
        <div class="dashboard-header-inner">
            <div>
                <div class="admin-badge">🛡 Admin Panel</div>
                <h1 class="dashboard-title" style="color:#fff;">Property Approvals</h1>
                <p class="dashboard-subtitle" style="color:rgba(255,255,255,.7);">
                    @Model.Count pending propert@(Model.Count == 1 ? "y" : "ies") awaiting review
                </p>
            </div>
        </div>
    </div>

    <div class="dashboard-body">

        @if (!string.IsNullOrEmpty(ViewBag.Success?.ToString()))
        {
            <div class="alert alert-success">✓ @ViewBag.Success</div>
        }
        @if (!string.IsNullOrEmpty(ViewBag.Error?.ToString()))
        {
            <div class="alert alert-error">⚠ @ViewBag.Error</div>
        }

        @if (Model.Count == 0)
        {
            <div class="empty-state">
                <div class="empty-icon">✅</div>
                <h3>All Clear!</h3>
                <p>No properties are pending review. Great job!</p>
            </div>
        }
        else
        {
            <div class="admin-grid">
                @foreach (var p in Model)
                {
                    <div class="admin-card">

                        <!-- Image -->
                        <div class="admin-card-img"
                             style="@(!string.IsNullOrEmpty(p.Images.FirstOrDefault()?.ImageUrl) ? $"background-image:url('{p.Images.FirstOrDefault()!.ImageUrl}');background-size:cover;background-position:center;" : "")">
                            @if (!p.Images.Any()) { <span>🏠</span> }
                            <div class="admin-card-status">⏳ Pending</div>
                            @if (p.Images.Count > 1)
                            {
                                <div class="admin-img-count">+@(p.Images.Count - 1) more</div>
                            }
                        </div>

                        <div class="admin-card-body">
                            <!-- Title + Meta -->
                            <h3 class="admin-card-title">@p.Title</h3>
                            <div class="admin-card-meta">
                                <span>📍 @p.City</span>
                                <span>@p.PropertyType</span>
                                <span>@p.BHKType</span>
                            </div>
                            <div class="admin-card-price">
                                ₹@p.Price.ToString("N0")
                                <span>@(p.ListingType == "Rent" ? "/mo" : " sale")</span>
                            </div>

                            <!-- Description excerpt -->
                            <p class="admin-card-desc">
                                @(p.Description.Length > 120 ? p.Description[..120] + "…" : p.Description)
                            </p>

                            <!-- Owner info -->
                            <div class="admin-owner-info">
                                <div class="admin-owner-avatar">
                                    @(p.OwnerName.Length > 0 ? p.OwnerName[0].ToString().ToUpper() : "?")
                                </div>
                                <div>
                                    <div class="admin-owner-name">@p.OwnerName</div>
                                    <div class="admin-owner-meta">
                                        Listed @p.CreatedAt.ToString("MMM dd, yyyy")
                                    </div>
                                </div>
                            </div>

                            <!-- Action Buttons -->
                            <div class="admin-actions">
                                <form asp-controller="Admin"
                                      asp-action="ApproveRejectProperty"
                                      method="post"
                                      onsubmit="return confirm('Approve this property?')">

                                    @Html.AntiForgeryToken()

                                    <input type="hidden" name="id" value="@p.PropertyId" />
                                    <input type="hidden" name="isApproved" value="true" />

                                    <button type="submit" class="btn btn-approve">
                                        ✅ Approve
                                    </button>
                                </form>
                                <a href="/Admin/Reject/@p.PropertyId" class="btn btn-reject">
                                    ❌ Reject
                                </a>
                            </div>
                        </div>
                    </div>
                }
            </div>
        }
    </div>
</div>

@section HeadStyles {
<style>

/* PAGE */
.dashboard-page {
    padding-top: 80px;
    min-height: 100vh;
}

/* HEADER */
.dashboard-header {
    padding: 2.5rem 2rem;
    background: linear-gradient(135deg, #1e1b4b 0%, #312e81 100%);
    margin: auto 300px;
    border-radius: 20px;
}

.dashboard-header-inner {
    max-width: 1200px;
    margin: 0 auto;
}

.admin-badge {
    display: inline-block;
    padding: 0.3rem 0.8rem;
    background: rgba(255,255,255,0.1);
    border-radius: 20px;
    font-size: 0.75rem;
    font-weight: 600;
    color: #fff;
    margin-bottom: 0.5rem;
}

.dashboard-title {
    font-size: 1.8rem;
    font-weight: 700;
    color: #fff;
}

.dashboard-subtitle {
    color: rgba(255,255,255,0.7);
    font-size: 0.9rem;
}

/* BODY */
.dashboard-body {
    max-width: 1200px;
    margin: auto;
    padding: 2rem;
}

/* GRID */
.admin-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(340px, 1fr));
    gap: 1.5rem;
}

/* CARD */
.admin-card {
    background: var(--bg-card);
    border-radius: 12px;
    overflow: hidden;
    border: 1px solid var(--border-subtle);
    transition: 0.25s;
}

.admin-card:hover {
    transform: translateY(-4px);
}

/* IMAGE */
.admin-card-img {
    height: 200px;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 3rem;
    background: #0f172a;
    position: relative;
}

/* STATUS */
.admin-card-status {
    position: absolute;
    top: 10px;
    left: 10px;
    background: rgba(245, 158, 11, 0.2);
    color: #f59e0b;
    padding: 4px 10px;
    font-size: 0.7rem;
    border-radius: 20px;
}

/* IMAGE COUNT */
.admin-img-count {
    position: absolute;
    bottom: 10px;
    right: 10px;
    background: rgba(0,0,0,0.6);
    padding: 3px 8px;
    font-size: 0.7rem;
    border-radius: 20px;
}

/* BODY CONTENT */
.admin-card-body {
    padding: 1.2rem;
}

/* TITLE */
.admin-card-title {
    font-size: 1.1rem;
    font-weight: 600;
}

/* META */
.admin-card-meta {
    display: flex;
    flex-wrap: wrap;
    gap: 6px;
    font-size: 0.75rem;
    color: var(--text-muted);
    margin: 6px 0;
}

.admin-card-meta span {
    background: rgba(99,102,241,0.1);
    padding: 3px 8px;
    border-radius: 20px;
}

/* PRICE */
.admin-card-price {
    font-size: 1.2rem;
    font-weight: bold;
    color: #a78bfa;
    margin-bottom: 8px;
}

.admin-card-price span {
    font-size: 0.75rem;
    color: var(--text-muted);
}

/* DESCRIPTION */
.admin-card-desc {
    font-size: 0.85rem;
    color: var(--text-muted);
    margin-bottom: 12px;
}

/* OWNER */
.admin-owner-info {
    display: flex;
    gap: 10px;
    align-items: center;
    margin-bottom: 12px;
}

.admin-owner-avatar {
    width: 35px;
    height: 35px;
    background: var(--accent-1);
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
}

.admin-owner-name {
    font-size: 0.85rem;
    font-weight: 600;
}

.admin-owner-meta {
    font-size: 0.7rem;
    color: var(--text-muted);
}

/* ACTION BUTTONS */
.admin-actions {
    display: flex;
    gap: 10px;
}

.admin-actions form {
    flex: 1;
}

.admin-actions form button {
    width: 100%;
}

.btn-reject {
    flex: 1;
}
.btn-approve {
    flex: 1;
    background: #10b981;
    border: none;
    padding: 8px;
    border-radius: 8px;
    color: white;
    cursor: pointer;
}

.btn-approve:hover {
    background: #059669;
}

.btn-reject {
    flex: 1;
    background: #ef4444;
    padding: 8px;
    border-radius: 8px;
    text-align: center;
    color: white;
    text-decoration: none;
}

.btn-reject:hover {
    background: #dc2626;
}

/* ALERTS */
.alert {
    padding: 10px;
    border-radius: 8px;
    margin-bottom: 1rem;
}

.alert-success {
    background: #065f46;
    color: #d1fae5;
}

.alert-error {
    background: #7f1d1d;
    color: #fecaca;
}

/* EMPTY STATE */
.empty-state {
    text-align: center;
    padding: 4rem;
}

.empty-icon {
    font-size: 3rem;
}

</style>
}
