@model List<RentalsAndProperties.Web.Models.PropertyDetailModel>
@{
    ViewData["Title"] = "Admin – Pending Approvals";
}

<div class="dashboard-page">
    <div class="dashboard-header" style="background:linear-gradient(135deg,#1e1b4b 0%,#312e81 100%);">
        <div class="dashboard-header-inner">
            <div>
                <div class="admin-badge">🛡 Admin Panel</div>
                <h1 class="dashboard-title" style="color:#fff;">Property Approvals</h1>
                <p class="dashboard-subtitle" style="color:rgba(255,255,255,.7);">
                    @Model.Count pending propert@(Model.Count == 1 ? "y" : "ies") awaiting review
                </p>
            </div>
        </div>
    </div>

    <div class="dashboard-body">

        @if (!string.IsNullOrEmpty(ViewBag.Success?.ToString()))
        {
            <div class="alert alert-success">✓ @ViewBag.Success</div>
        }
        @if (!string.IsNullOrEmpty(ViewBag.Error?.ToString()))
        {
            <div class="alert alert-error">⚠ @ViewBag.Error</div>
        }

        @if (Model.Count == 0)
        {
            <div class="empty-state">
                <div class="empty-icon">✅</div>
                <h3>All Clear!</h3>
                <p>No properties are pending review. Great job!</p>
            </div>
        }
        else
        {
            <div class="admin-grid">
                @foreach (var p in Model)
                {
                    <div class="admin-card">

                        <!-- Image -->
                        <div class="admin-card-img"
                             style="@(!string.IsNullOrEmpty(p.Images.FirstOrDefault()?.ImageUrl) ? $"background-image:url('{p.Images.FirstOrDefault()!.ImageUrl}');background-size:cover;background-position:center;" : "")">
                            @if (!p.Images.Any()) { <span>🏠</span> }
                            <div class="admin-card-status">⏳ Pending</div>
                            @if (p.Images.Count > 1)
                            {
                                <div class="admin-img-count">+@(p.Images.Count - 1) more</div>
                            }
                        </div>

                        <div class="admin-card-body">
                            <!-- Title + Meta -->
                            <h3 class="admin-card-title">@p.Title</h3>
                            <div class="admin-card-meta">
                                <span>📍 @p.City</span>
                                <span>@p.PropertyType</span>
                                <span>@p.BHKType</span>
                            </div>
                            <div class="admin-card-price">
                                ₹@p.Price.ToString("N0")
                                <span>@(p.ListingType == "Rent" ? "/mo" : " sale")</span>
                            </div>

                            <!-- Description excerpt -->
                            <p class="admin-card-desc">
                                @(p.Description.Length > 120 ? p.Description[..120] + "…" : p.Description)
                            </p>

                            <!-- Owner info -->
                            <div class="admin-owner-info">
                                <div class="admin-owner-avatar">
                                    @(p.OwnerName.Length > 0 ? p.OwnerName[0].ToString().ToUpper() : "?")
                                </div>
                                <div>
                                    <div class="admin-owner-name">@p.OwnerName</div>
                                    <div class="admin-owner-meta">
                                        Trust Score: @p.OwnerTrustScore.ToString("F0")/100 ·
                                        Listed @p.CreatedAt.ToString("MMM dd, yyyy")
                                    </div>
                                </div>
                            </div>

                            <!-- Action Buttons -->
                            <div class="admin-actions">
                                <form asp-controller="Admin" asp-action="Approve"
                                      asp-route-id="@p.PropertyId" method="post"
                                      onsubmit="return confirm('Approve this property?')">
                                    @Html.AntiForgeryToken()
                                    <button type="submit" class="btn btn-approve">
                                        ✅ Approve
                                    </button>
                                </form>
                                <a href="/Admin/Reject/@p.PropertyId" class="btn btn-reject">
                                    ❌ Reject
                                </a>
                            </div>
                        </div>

                        <!-- Image strip -->
                        @if (p.Images.Count > 1)
                        {
                            <div class="admin-img-strip">
                                @foreach (var img in p.Images.Take(4))
                                {
                                    <img src="@img.ImageUrl" alt="Property image" loading="lazy" />
                                }
                            </div>
                        }
                    </div>
                }
            </div>
        }
    </div>
</div>

@section HeadStyles {
    <style>
        .dashboard-page { padding-top:68px; min-height:100vh; }
        .dashboard-header { padding:2.5rem 2rem; }
        .dashboard-header-inner { max-width:1280px; margin:0 auto; }
        .admin-badge { display:inline-flex; align-items:center; gap:.4rem; padding:.3rem .85rem; background:rgba(255,255,255,.1); border:1px solid rgba(255,255,255,.2); border-radius:100px; font-size:.75rem; font-weight:700; color:rgba(255,255,255,.9); text-transform:uppercase; letter-spacing:.05em; margin-bottom:.75rem; }
        .dashboard-title { font-size:1.75rem; font-weight:800; }
        .dashboard-subtitle { margin-top:.3rem; }
        .dashboard-body { max-width:1280px; margin:0 auto; padding:2rem; }
        .admin-grid { display:grid; grid-template-columns:repeat(auto-fill,minmax(360px,1fr)); gap:1.5rem; }
        .admin-card { background:var(--bg-card); border:1px solid var(--border-subtle); border-radius:var(--radius-lg); overflow:hidden; transition:transform .3s var(--spring),box-shadow .3s; }
        .admin-card:hover { transform:translateY(-4px); box-shadow:var(--shadow-card); }
        .admin-card-img { height:200px; background:var(--gradient-card); display:flex; align-items:center; justify-content:center; font-size:3rem; position:relative; }
        .admin-card-status { position:absolute; top:.85rem; left:.85rem; padding:.3rem .75rem; background:rgba(247,151,30,.2); border:1px solid rgba(247,151,30,.4); color:#f59e0b; font-size:.72rem; font-weight:700; text-transform:uppercase; letter-spacing:.05em; border-radius:100px; }
        .admin-img-count { position:absolute; bottom:.85rem; right:.85rem; padding:.25rem .6rem; background:rgba(0,0,0,.6); color:#fff; font-size:.72rem; font-weight:600; border-radius:100px; }
        .admin-card-body { padding:1.25rem; }
        .admin-card-title { font-size:1.05rem; font-weight:700; margin-bottom:.5rem; }
        .admin-card-meta { display:flex; flex-wrap:wrap; gap:.5rem; font-size:.78rem; color:var(--text-muted); margin-bottom:.5rem; }
        .admin-card-meta span { padding:.2rem .5rem; background:rgba(99,102,241,.08); border-radius:100px; }
        .admin-card-price { font-family:'Syne',sans-serif; font-size:1.25rem; font-weight:700; color:#a78bfa; margin-bottom:.75rem; }
        .admin-card-price span { font-size:.75rem; font-weight:500; color:var(--text-muted); }
        .admin-card-desc { font-size:.85rem; color:var(--text-secondary); line-height:1.6; margin-bottom:1rem; }
        .admin-owner-info { display:flex; align-items:center; gap:.75rem; padding:.75rem; background:rgba(99,102,241,.05); border-radius:var(--radius-sm); margin-bottom:1rem; }
        .admin-owner-avatar { width:36px; height:36px; border-radius:50%; background:var(--gradient-btn); display:flex; align-items:center; justify-content:center; font-size:.9rem; font-weight:700; color:#fff; flex-shrink:0; }
        .admin-owner-name { font-weight:600; font-size:.875rem; }
        .admin-owner-meta { font-size:.75rem; color:var(--text-muted); margin-top:.1rem; }
        .admin-actions { display:flex; gap:.75rem; }
        .btn-approve { flex:1; padding:.7rem; background:linear-gradient(135deg,#10b981,#059669); color:#fff; border:none; border-radius:var(--radius-md); font-weight:700; font-size:.875rem; cursor:pointer; transition:transform .2s,box-shadow .2s; }
        .btn-approve:hover { transform:translateY(-2px); box-shadow:0 6px 20px rgba(16,185,129,.3); }
        .btn-reject { flex:1; padding:.7rem; background:linear-gradient(135deg,#ef4444,#dc2626); color:#fff; border:none; border-radius:var(--radius-md); font-weight:700; font-size:.875rem; cursor:pointer; transition:transform .2s,box-shadow .2s; text-align:center; display:flex; align-items:center; justify-content:center; }
        .btn-reject:hover { transform:translateY(-2px); box-shadow:0 6px 20px rgba(239,68,68,.3); }
        .admin-img-strip { display:flex; gap:2px; padding:2px; background:var(--border-subtle); }
        .admin-img-strip img { flex:1; height:50px; object-fit:cover; }
        .empty-state { text-align:center; padding:5rem 2rem; }
        .empty-icon { font-size:4rem; margin-bottom:1rem; }
        .empty-state h3 { font-size:1.5rem; margin-bottom:.5rem; }
        .empty-state p { color:var(--text-secondary); }
    </style>
}
