@model List<RentalsAndProperties.Web.ViewModels.Report.ReportViewModel>
@{
    ViewData["Title"] = "Admin – Reports";
    var currentFilter = ViewBag.Filter as string ?? "";
}

<div class="dashboard-page">
    <div class="dashboard-header" style="background:linear-gradient(135deg,#1e1b4b 0%,#312e81 100%);">
        <div class="dashboard-header-inner">
            <div>
                <div class="admin-badge">🛡 Admin Panel</div>
                <h1 class="dashboard-title" style="color:#fff;">Reports</h1>
                <p class="dashboard-subtitle" style="color:rgba(255,255,255,.7);">
                    @Model.Count report@(Model.Count != 1 ? "s" : "") found
                </p>
            </div>
        </div>
    </div>

    <div class="dashboard-body">

        @if (!string.IsNullOrEmpty(ViewBag.Success?.ToString()))
        {
            <div class="alert alert-success">✓ @ViewBag.Success</div>
        }
        @if (!string.IsNullOrEmpty(ViewBag.Error?.ToString()))
        {
            <div class="alert alert-error">⚠ @ViewBag.Error</div>
        }

        <!-- Filter Bar -->
        <div class="filter-bar">
            @foreach (var f in new[] {
                       @*value (used in URL) , value (used in URL)*@
                        ("", "All"), ("Pending", "Pending"), ("Resolved", "Resolved"),
                        ("Recent", "Recent"), ("Oldest", "Oldest")
                        })
            {
                <a href="/Admin/Reports@(string.IsNullOrEmpty(f.Item1) ? "" : $"?filter={f.Item1}")"
                   class="filter-pill @(currentFilter == f.Item1 ? "active" : "")">
                    @f.Item2
                </a>
            }
        </div>

        @if (!Model.Any())
        {
            <div class="empty-state">
                <div class="empty-icon">✅</div>
                <h3>No Reports</h3>
                <p>No reports match the selected filter.</p>
            </div>
        }
        else
        {
            <div class="dash-table-wrap">
                <table class="dash-table">
                    <thead>
                        <tr>
                            <th>Reporter</th>
                            <th>Title</th>
                            <th>Reason</th>
                            <th>Description</th>
                            <th>Status</th>
                            <th>Date</th>
                            <th>Actions</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var r in Model)
                        {
                            <tr>
                                <td>
                                    <div style="font-weight:600;font-size:.875rem;">@r.ReporterName</div>
                                </td>
                                <td>@(string.IsNullOrEmpty(r.TargetTitle) ? "N/A" : r.TargetTitle)<span class="s-chip">@r.TargetType</span></td>

                                <td style="font-weight:500;">@r.Reason</td>
                                <td style="font-size:.82rem;color:var(--text-secondary);max-width:200px;">
                                    @(r.Description?.Length > 60 ? r.Description[..60] + "…" : r.Description ?? "—")
                                </td>
                                <td>
                                    <span class="status-pill status-@r.Status.ToLower()">@r.Status</span>
                                </td>
                                <td style="font-size:.8rem;color:var(--text-muted);">
                                    @r.CreatedAt.ToString("MMM dd, yyyy")
                                </td>
                                <td>
                                    @if (r.Status == "Pending" || r.Status == "UnderReview")
                                    {
                                        <div style="display:flex;gap:.5rem;">
                                            <form asp-controller="Admin" asp-action="ResolveReport"
                                                  asp-route-id="@r.ReportId" method="post">
                                                @Html.AntiForgeryToken()
                                                <button type="submit" class="btn btn-sm"
                                                        style="background:rgba(67,233,123,.15);color:#43e97b;border:1px solid rgba(67,233,123,.3);"
                                                        onclick="return confirm('Resolve this report?')">
                                                    ✓ Resolve
                                                </button>
                                            </form>
                                            <form asp-controller="Admin" asp-action="RejectReport"
                                                  asp-route-id="@r.ReportId" method="post">
                                                @Html.AntiForgeryToken()
                                                <button type="submit" class="btn btn-sm btn-danger"
                                                        onclick="return confirm('Reject this report?')">
                                                    ✕ Reject
                                                </button>
                                            </form>
                                        </div>
                                    }
                                    else
                                    {
                                        <span style="font-size:.78rem;color:var(--text-muted);">
                                            @(r.ResolvedAt?.ToString("MMM dd") ?? "—")
                                        </span>
                                    }
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        }

    </div>
</div>

@section HeadStyles {
    <style>
        .dashboard-page {
            padding-top: 68px;
            min-height: 100vh;
        }

        .dashboard-header {
            padding: 2.5rem 2rem;
            margin: auto 220px;
            border-radius: 20px;
        }

        .dashboard-header-inner {
            max-width: 1280px;
            margin: auto;
        }

        .admin-badge {
            display: inline-flex;
            align-items: center;
            gap: .4rem;
            padding: .35rem .9rem;
            background: rgba(255,255,255,.1);
            border: 1px solid rgba(255,255,255,.2);
            border-radius: 100px;
            font-size: .75rem;
            font-weight: 700;
            color: rgba(255,255,255,.9);
            text-transform: uppercase;
            margin-bottom: .7rem;
        }

        .dashboard-title {
            font-size: 1.8rem;
            font-weight: 800;
            color: #fff;
        }

        .dashboard-subtitle {
            color: rgba(255,255,255,.7);
        }

        .dashboard-body {
            max-width: 1280px;
            margin: auto;
            padding: 2rem;
        }

        .filter-bar {
            display: flex;
            gap: .6rem;
            flex-wrap: wrap;
            margin-bottom: 1.5rem;
        }

        .filter-pill {
            padding: .4rem 1rem;
            border-radius: 100px;
            font-size: .8rem;
            font-weight: 600;
            border: 1px solid var(--border-subtle);
            color: var(--text-secondary);
            text-decoration: none;
            transition: all .2s ease;
        }

            .filter-pill:hover {
                background: rgba(99,102,241,.2);
            }

            .filter-pill.active {
                background: var(--accent-1);
                color: #fff;
                border-color: var(--accent-1);
            }

        .dash-table-wrap {
            background: var(--bg-card);
            border: 1px solid var(--border-subtle);
            border-radius: 14px;
            padding: 1rem 1.2rem;
            box-shadow: 0 10px 30px rgba(0,0,0,.2);
            overflow-x: auto;
        }

        .dash-table {
            width: 100%;
            border-collapse: collapse;
        }

            .dash-table thead {
                border-bottom: 1px solid var(--border-subtle);
            }

            .dash-table th {
                text-align: left;
                font-size: .75rem;
                color: var(--text-muted);
                padding: .8rem 0;
                text-transform: uppercase;
                letter-spacing: .05em;
            }

            .dash-table td {
                padding: 1rem 0;
                font-size: .85rem;
                border-bottom: 1px solid rgba(255,255,255,.05);
            }

            .dash-table tbody tr:hover {
                background: rgba(99,102,241,.06);
            }

        .reporter-name {
            font-weight: 600;
            font-size: .88rem;
        }

        .report-desc {
            font-size: .82rem;
            color: var(--text-secondary);
            max-width: 220px;
        }

        .s-chip {
            background: rgba(99,102,241,.15);
            color: #a78bfa;
            padding: 3px 10px;
            border-radius: 20px;
            font-size: .7rem;
        }

        .status-pill {
            padding: 4px 10px;
            border-radius: 20px;
            font-size: .7rem;
            font-weight: 600;
        }

        .status-pending {
            background: rgba(245,158,11,.2);
            color: #f59e0b;
        }

        .status-resolved {
            background: rgba(16,185,129,.2);
            color: #10b981;
        }

        .status-rejected {
            background: rgba(239,68,68,.2);
            color: #ef4444;
        }

        .status-underreview {
            background: rgba(99,102,241,.2);
            color: #a78bfa;
        }

        .dash-table td:last-child div {
            display: flex;
            gap: 6px;
        }

        .btn {
            padding: 6px 10px;
            font-size: .75rem;
            border-radius: 6px;
            border: none;
            cursor: pointer;
            transition: .2s;
        }

        .btn-success {
            background: rgba(16,185,129,.15);
            color: #10b981;
            border: 1px solid rgba(16,185,129,.3);
        }

            .btn-success:hover {
                background: rgba(16,185,129,.3);
            }

        .btn-danger {
            background: #ef4444;
            color: #fff;
        }

            .btn-danger:hover {
                background: #dc2626;
            }

        .alert {
            padding: 10px;
            border-radius: 8px;
            margin-bottom: 1rem;
        }

        .alert-success {
            background: #065f46;
            color: #d1fae5;
        }

        .alert-error {
            background: #7f1d1d;
            color: #fecaca;
        }

        .empty-state {
            text-align: center;
            padding: 4rem 2rem;
        }

        .empty-icon {
            font-size: 3rem;
            margin-bottom: 10px;
        }

    </style>
}