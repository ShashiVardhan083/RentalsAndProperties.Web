@model RentalsAndProperties.Web.ViewModels.Auth.OtpVerifyViewModel

@{
    ViewData["Title"] = "Verify OTP & Complete Registration";
}

<div class="auth-page">

    <div class="auth-card">

        <h1>Verify OTP</h1>
        <p>Enter the OTP and complete your profile</p>
        @if (ViewBag.DevOtp != null)
        {
            <div class="alert alert-info" style="color:black">
                <strong>Dev OTP:</strong> @ViewBag.DevOtp
            </div>
        }
        @Html.ValidationSummary(true, "", new { @class = "alert alert-danger" })

        <form asp-action="VerifyOtp" asp-controller="Auth" method="post">

            @Html.AntiForgeryToken()
            <div class="form-group">
                @Html.LabelFor(m => m.PhoneNumber)
                @Html.TextBoxFor(m => m.PhoneNumber, new {
                @class = "form-control",
                                @readonly = "readonly"
                                })
            </div>

            <div class="form-group">
                @Html.LabelFor(m => m.OtpCode)

                @Html.TextBoxFor(m => m.OtpCode, new {
                                @class = "form-control",
                                maxlength = "6",
                                placeholder = "Enter 6-digit OTP"
                                })

                @Html.ValidationMessageFor(m => m.OtpCode, "", new { @class = "text-danger" })
            </div>

            <div class="form-group">
                @Html.LabelFor(m => m.FullName)

                @Html.TextBoxFor(m => m.FullName, new {
                                @class = "form-control",
                                placeholder = "Enter your full name"
                                })

                @Html.ValidationMessageFor(m => m.FullName, "", new { @class = "text-danger" })
            </div>

            <div class="form-group">
                @Html.LabelFor(m => m.Email)

                @Html.TextBoxFor(m => m.Email, new {
                                @class = "form-control",
                                type = "email",
                                placeholder = "Enter your email (optional)"
                                })

                @Html.ValidationMessageFor(m => m.Email, "", new { @class = "text-danger" })
            </div>

            <div class="form-group">
                @Html.LabelFor(m => m.Password)

                @Html.PasswordFor(m => m.Password, new {
                                @class = "form-control",
                                placeholder = "Enter password"
                                })

                @Html.ValidationMessageFor(m => m.Password, "", new { @class = "text-danger" })
            </div>

            <div class="form-group">
                @Html.LabelFor(m => m.ConfirmPassword)

                @Html.PasswordFor(m => m.ConfirmPassword, new {
                                @class = "form-control",
                                placeholder = "Confirm password"
                                })

                @Html.ValidationMessageFor(m => m.ConfirmPassword, "", new { @class = "text-danger" })
            </div>

            <button type="submit" class="btn btn-primary">
                Verify & Create Account →
            </button>

        </form>

        <div style="margin-top:10px;">
            <a href="/Auth/Register">← Change Phone Number</a>
        </div>

    </div>
</div>


<style>
    
    .auth-page {
        min-height: 100vh;
        display: flex;
        justify-content: center;
        align-items: center;
        background: linear-gradient(135deg, #eef2ff, #f8fafc);
        padding: 20px;
        font-family: 'Segoe UI', sans-serif;
    }

    .auth-card {
        width: 100%;
        max-width: 450px;
        background: #fff;
        padding: 30px;
        border-radius: 14px;
        box-shadow: 0 10px 30px rgba(0,0,0,0.08);
    }

        .auth-card h1 {
            margin-bottom: 6px;
            font-size: 22px;
            font-weight: 600;
            color: #111827;
        }

        .auth-card p {
            margin-bottom: 20px;
            font-size: 14px;
            color: #6b7280;
        }

    .form-group {
        margin-bottom: 16px;
    }

    .form-control {
        width: 100%;
        padding: 10px 12px;
        border-radius: 8px;
        border: 1px solid #ccc;
        font-size: 14px;
        transition: 0.2s;
    }

        .form-control:focus {
            border-color: #4f46e5;
            outline: none;
            box-shadow: 0 0 0 2px rgba(79,70,229,0.15);
        }

    .input-error {
        border-color: #dc2626 !important;
        background: #fff5f5;
    }

    .text-danger {
        font-size: 12px;
        color: #dc2626;
    }

    .btn {
        width: 100%;
        padding: 12px;
        border-radius: 8px;
        border: none;
        font-weight: 600;
        cursor: pointer;
    }

    .btn-primary {
        background: #4f46e5;
        color: white;
    }

        .btn-primary:hover {
            background: #4338ca;
        }

    .btn.loading {
        opacity: 0.7;
        pointer-events: none;
    }

    .alert {
        padding: 10px;
        border-radius: 8px;
        font-size: 13px;
        margin-bottom: 15px;
    }

    .alert-danger {
        background: #fee2e2;
        color: #991b1b;
    }

    .auth-card a {
        color: #4f46e5;
        text-decoration: none;
    }

        .auth-card a:hover {
            text-decoration: underline;
        }
</style>           


<script>
    document.addEventListener("DOMContentLoaded", function () {

        const form = document.querySelector("form");
        const otpInput = document.querySelector("input[name='OtpCode']");
        const password = document.querySelector("input[name='Password']");
        const confirm = document.querySelector("input[name='ConfirmPassword']");
        const btn = document.querySelector("button[type='submit']");

        if (!form) return;

        const otpRegex = /^\d{6}$/;

        if (otpInput) {
            otpInput.addEventListener("input", function () {
                const value = otpInput.value.trim();

                otpInput.classList.toggle("input-error", !otpRegex.test(value));
            });
        }

        function validatePasswords() {
            if (!password || !confirm) return;

            if (confirm.value && password.value !== confirm.value) {
                confirm.classList.add("input-error");
            } else {
                confirm.classList.remove("input-error");
            }
        }

        if (password && confirm) {
            password.addEventListener("input", validatePasswords);
            confirm.addEventListener("input", validatePasswords);
        }

        form.addEventListener("submit", function (e) {

            let valid = true;

            if (otpInput && !otpRegex.test(otpInput.value.trim())) {
                otpInput.classList.add("input-error");
                valid = false;
            }

            if (password && confirm && password.value !== confirm.value) {
                confirm.classList.add("input-error");
                valid = false;
            }

            if (!valid) {
                e.preventDefault();
                alert("Please fix the errors before submitting.");
                return;
            }

            if (btn) {
                btn.classList.add("loading");
                btn.innerText = "Verifying...";
            }

        });

    });
</script>