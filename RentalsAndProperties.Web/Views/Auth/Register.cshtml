@model RentalsAndProperties.Web.ViewModels.Auth.RegisterPhoneViewModel

@{
    ViewData["Title"] = "Create Account";
}

<div class="auth-page">

    <div class="auth-card">

        <h1>Create Account</h1>
        <p>Enter your phone number to receive OTP</p>
        @Html.ValidationSummary(true, "", new { @class = "alert alert-danger" })
        <form asp-action="Register" asp-controller="Auth" method="post">

            @Html.AntiForgeryToken()

            <div class="form-group">

                @Html.LabelFor(m => m.PhoneNumber, new { @class = "form-label" })

                @Html.TextBoxFor(m => m.PhoneNumber, new
                {
                    @class = "form-control",
                                placeholder = "+91 9876543210",
                                type = "tel"
                                })

                @Html.ValidationMessageFor(m => m.PhoneNumber,
                                "",
                                new { @class = "text-danger" })

            </div>

            <div class="alert alert-info">
                A 6-digit OTP will be sent to this number.
            </div>

            <button type="submit" class="btn btn-primary">
                Send OTP →
            </button>

        </form>

        <div>
            <span style="color: darkturquoise">Already have an account?</span>
            <a href="/Auth/Login">Sign in</a>
        </div>

    </div>
</div>


<style>
    
    .auth-page {
        min-height: 100vh;
        display: flex;
        justify-content: center;
        align-items: center;
        background: linear-gradient(135deg, #eef2ff, #f8fafc);
        padding: 20px;
        font-family: 'Segoe UI', sans-serif;
    }

    .auth-card {
        width: 100%;
        max-width: 420px;
        background: #fff;
        padding: 30px;
        border-radius: 14px;
        box-shadow: 0 10px 30px rgba(0,0,0,0.08);
        text-align: center;
    }

        
        .auth-card h1 {
            color: darkcyan;
            margin-bottom: 8px;
            font-size: 24px;
            font-weight: 600;
        }

        .auth-card p {
            margin-bottom: 20px;
            color: #666;
            font-size: 14px;
        }

    
    .form-group {
        text-align: left;
        margin-bottom: 18px;
    }

    .form-label {
        display: block;
        margin-bottom: 6px;
        font-weight: 500;
        color: #333;
    }

    .form-control {
        width: 100%;
        padding: 10px 12px;
        border-radius: 8px;
        border: 1px solid #ccc;
        transition: 0.2s ease;
        font-size: 14px;
    }

        .form-control:focus {
            border-color: #4f46e5;
            outline: none;
            box-shadow: 0 0 0 2px rgba(79,70,229,0.15);
        }

    
    .text-danger {
        font-size: 12px;
        color: #dc2626;
    }

    .alert {
        padding: 10px 12px;
        border-radius: 8px;
        margin-bottom: 15px;
        font-size: 13px;
    }


    .alert-info {
        background: #e0f2fe;
        color: #075985;
    }

    .alert-danger {
        background-color: #fee2e2;
        color: #991b1b;
        border: 1px solid #fecaca;
    }

    .btn {
        width: 100%;
        padding: 12px;
        border-radius: 8px;
        border: none;
        font-weight: 600;
        cursor: pointer;
    }

    .btn-primary {
        background: #4f46e5;
        color: #fff;
    }

        .btn-primary:hover {
            background: #4338ca;
        }

    .btn.loading {
        opacity: 0.7;
        pointer-events: none;
    }

    .input-error {
        border: 1px solid #dc2626 !important;
        background-color: #fff5f5;
    }

    .input-error:focus {
        border-color: #dc2626;
        box-shadow: 0 0 0 2px rgba(220, 38, 38, 0.2);
    }
    .auth-card a {
        color: #4f46e5;
        text-decoration: none;
        font-weight: 500;
    }

        .auth-card a:hover {
            text-decoration: underline;
        }
</style>    

<script>
    document.addEventListener("DOMContentLoaded", function () {

        const form = document.querySelector("form");
        const input = document.querySelector("input[name='PhoneNumber']");
        const btn = document.querySelector("button[type='submit']");

        input.addEventListener("input", function () {
            const value = input.value.trim();

            const regex = /^(?:\+91|91)?[6-9]\d{9}$/;

            if (!regex.test(value)) {
                input.classList.add("input-error");
            } else {
                input.classList.remove("input-error");
            }
        });

        form.addEventListener("submit", function (e) {

            const value = input.value.trim();
            const regex = /^(?:\+91|91)?[6-9]\d{9}$/;

            if (!regex.test(value)) {
                e.preventDefault();
                alert("Please enter a valid phone number");
                return;
            }

            btn.classList.add("loading");
            btn.innerText = "Sending OTP...";
        });

    });
</script>