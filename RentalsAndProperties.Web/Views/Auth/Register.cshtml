@model RentalsAndProperties.Web.ViewModels.Auth.RegisterPhoneViewModel
@{
    ViewData["Title"] = "Create Account";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<div class="auth-page">
    <div class="hero-orb orb-1" aria-hidden="true"></div>
    <div class="hero-orb orb-2" aria-hidden="true"></div>

    <div class="auth-card" role="main" aria-labelledby="registerTitle">

        <!-- Progress indicator -->
        <div class="auth-progress" style="width:33%;" role="progressbar" aria-valuenow="33" aria-valuemin="0" aria-valuemax="100" aria-label="Step 1 of 3"></div>

        <!-- Step indicators -->
        <div class="step-indicators" aria-label="Registration steps">
            <div class="step-dot active" title="Step 1: Phone"></div>
            <div class="step-dot" title="Step 2: Verify OTP"></div>
            <div class="step-dot" title="Step 3: Profile"></div>
        </div>

        <!-- Logo + Title -->
        <div class="auth-logo">
            <div class="auth-logo-icon" aria-hidden="true">📱</div>
            <h1 class="auth-title" id="registerTitle">Get Started</h1>
            <p class="auth-subtitle">Enter your phone number to receive an OTP and create your account</p>
        </div>

        <!-- Server errors -->
        @if (!ViewData.ModelState.IsValid)
        {
            <div class="alert alert-error" role="alert">
                <span aria-hidden="true">⚠</span>
                <div>
                    @foreach (var error in ViewData.ModelState.Values.SelectMany(v => v.Errors))
                    {
                        <div>@error.ErrorMessage</div>
                    }
                </div>
            </div>
        }

        <form asp-action="Register" asp-controller="Auth" method="post"
              id="registerForm" novalidate autocomplete="on">

            @Html.AntiForgeryToken()

            @await Html.PartialAsync("_PhoneInput", Model.PhoneNumber,
            new ViewDataDictionary(ViewData) {
                        { "FieldId", "PhoneNumber" },
                        { "FieldName", "PhoneNumber" },
                        { "Label", "Mobile Number" },
                        { "Placeholder", "+91 98765 43210" }
                        })

            <span asp-validation-for="PhoneNumber" class="invalid-feedback"></span>

            <div class="alert alert-info" style="margin-top:.5rem;" role="note">
                <span aria-hidden="true">ℹ</span>
                <span>A 6-digit OTP will be sent to this number. Standard SMS rates may apply.</span>
            </div>

            <button type="submit" class="btn btn-primary btn-block btn-lg" id="sendOtpBtn">
                <span class="btn-text">Send OTP →</span>
                <span class="btn-spinner" aria-hidden="true"></span>
            </button>
        </form>

        <div class="auth-footer">
            Already have an account?
            <a href="/Auth/Login" class="auth-link">Sign in →</a>
        </div>

        <div class="auth-footer" style="margin-top:.5rem;font-size:.78rem;">
            By continuing, you agree to our
            <a href="/terms" class="auth-link">Terms of Service</a> and
            <a href="/privacy" class="auth-link">Privacy Policy</a>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        document.addEventListener('DOMContentLoaded', function () {
            const form   = document.getElementById('registerForm');
            const btn    = document.getElementById('sendOtpBtn');

            Validator.attachLiveValidation(form);

            form.addEventListener('submit', function (e) {
                const isValid = Validator.validateForm(form);
                if (!isValid) {
                    e.preventDefault();
                    Toast.error('Please enter a valid phone number.');
                    return;
                }
                setButtonLoading(btn, true);
            });
        });
    </script>
}
