@model RentalsAndProperties.Web.ViewModels.Transaction.TransactionViewModel

@{
    ViewData["Title"] = "Initiate Transaction";
}

<div class="tx-container">

    <h2>Initiate Transaction</h2>

    @* Property Summary *@
    <div class="summary-card">
        <div>
            <h4>@Model.PropertyTitle</h4>
            <p>📍 @Model.PropertyCity · @Model.PropertyType · @Model.BHKType</p>
            <p class="price">
                ₹@Model.PropertyPrice.ToString("N0") @*1234567 -> 12,34,567 (India culture)*@
                @if (Model.ListingType == "Rent")
                {
                    <span class="per">/mo</span>
                }
            </p>
        </div>
        <div class="owner-info">
            <div class="avatar">
                @(Model.OwnerName.Length > 0 ? Model.OwnerName[0].ToString().ToUpper() : "?")
            </div>
            <div>
                <div>@Model.OwnerName</div>
            </div>
        </div>
    </div>

    @Html.ValidationSummary(false, "", new { @class = "alert alert-danger" })

    @using (Html.BeginForm("Initiate", "Transaction", FormMethod.Post, new { id = "txForm" }))
    {
        @Html.AntiForgeryToken()

        @Html.HiddenFor(m => m.PropertyId)
        @Html.HiddenFor(m => m.ListingType)
        <div class="form-card">

            @* Transaction Type *@
            <div class="field-group">
                <label class="field-label">Transaction Type</label>

                <p>
                    @(Model.ListingType == "Rent" ? "🔑 Rent" : "🏡 Buy")
                </p>

                @Html.HiddenFor(m => m.TransactionType)
            </div>

            @* Payment Method *@
            <div class="field-group">
                <label class="field-label">Payment Method</label>
                @Html.ValidationMessageFor(m => m.PaymentMethod, "", new { @class = "field-error" })

                <div class="radio-group">
                    <label>
                        @Html.RadioButtonFor(m => m.PaymentMethod, "Online")
                        ⚡ Online — completes instantly
                    </label>

                    <label>
                        @Html.RadioButtonFor(m => m.PaymentMethod, "Offline")
                        🤝 Offline — both parties must confirm
                    </label>
                </div>
            </div>

            @* Amount *@
            <div class="amount-row">
                <span>Total Amount</span>
                <strong class="price">₹@Model.PropertyPrice.ToString("N0")</strong>
            </div>

            @* Actions *@
            <div class="actions">
                <a href="/Property/Details/@Model.PropertyId" class="btn btn-secondary">← Cancel</a>
                <button type="submit" class="btn btn-primary">Confirm Transaction</button>
            </div>

        </div>
    }

</div>

<style>
    .tx-container {
        max-width: 700px;
        margin: 2rem auto;
        padding: 0 1rem;
    }

    .summary-card {
        background: #1e293b;
        border-radius: 12px;
        padding: 1.2rem;
        display: flex;
        justify-content: space-between;
        align-items: center;
        flex-wrap: wrap;
        gap: 1rem;
        margin-bottom: 1.5rem;
    }

        .summary-card p {
            margin: 0.3rem 0;
            color: #94a3b8;
            font-size: 0.88rem;
        }

        .summary-card h4 {
            margin: 0 0 0.3rem; /*top right bottom left*/
        }

    .price {
        color: #22c55e;
        font-weight: 700;
        font-size: 1.1rem;
    }

    .per {
        font-size: 0.75rem;
        font-weight: 400;
        color: #94a3b8;
    }

    .owner-info {
        display: flex;
        align-items: center;
        gap: 0.6rem;
    }

    .avatar {
        width: 38px;
        height: 38px;
        background: #6366f1;
        border-radius: 50%;
        display: flex;
        align-items: center;
        justify-content: center;
        font-weight: 700;
        color: white;
    }

    .alert-error {
        background: rgba(239,68,68,0.1);
        border: 1px solid #ef4444;
        border-radius: 8px;
        padding: 0.8rem 1rem;
        margin-bottom: 1rem;
        color: #fca5a5;
        font-size: 0.88rem;
    }

    .form-card {
        background: #1e293b;
        border-radius: 12px;
        padding: 1.5rem;
    }

    .field-group {
        margin-bottom: 1.4rem;
    }

    .field-label {
        display: block;
        font-size: 0.8rem;
        font-weight: 600;
        color: #94a3b8;
        text-transform: uppercase;
        letter-spacing: 0.05em;
        margin-bottom: 0.6rem;
    }

    .field-error {
        display: block;
        color: #f87171;
        font-size: 0.8rem;
        margin-bottom: 0.4rem;
    }

    .radio-group {
        display: flex;
        flex-direction: column;
        gap: 0.6rem;
    }

        .radio-group label {
            display: flex;
            align-items: center;
            gap: 0.5rem;
            cursor: pointer;
            font-size: 0.92rem;
        }

        .radio-group input {
            accent-color: #6366f1;
        }

    .amount-row {
        display: flex;
        justify-content: space-between;
        align-items: center;
        background: #0f172a;
        border-radius: 8px;
        padding: 0.8rem 1rem;
        margin-bottom: 1.5rem;
        font-size: 0.95rem;
        color: #94a3b8;
    }

    .actions {
        display: flex;
        gap: 0.8rem;
    }

    .btn {
        padding: 0.55rem 1.2rem;
        border-radius: 8px;
        border: none;
        cursor: pointer;
        font-weight: 600;
        text-decoration: none;
        display: inline-block;
        font-size: 0.9rem;
    }

    .btn-primary {
        background: #6366f1;
        color: white;
    }

        .btn-primary:hover {
            background: #4f46e5;
        }

    .btn-secondary {
        background: #334155;
        color: white;
    }

        .btn-secondary:hover {
            background: #475569;
        }
</style>


<script>
    document.addEventListener("DOMContentLoaded", function () {

        // Get the form using your existing id
        var form = document.getElementById("txForm");

        if (!form) return;

        form.addEventListener("submit", function (e) {

            var isConfirmed = confirm("⚠️ Are you sure you want to confirm this transaction?");

            if (!isConfirmed) {
                e.preventDefault(); // stop form submission
            }

        });

    });
</script>