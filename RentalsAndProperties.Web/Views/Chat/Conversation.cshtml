@model RentalsAndProperties.Web.ViewModels.Chat.ChatConversationViewModel
@{
    ViewData["Title"] = $"Chat with {Model.OtherUserName}";
}

<div class="chat-page">
    <!-- Chat Header -->
    <div class="chat-header">
        <a href="/Chat" class="chat-back">←</a>
        <div class="chat-header-avatar">
            @(Model.OtherUserName.Length > 0 ? Model.OtherUserName[0].ToString().ToUpper() : "?")
        </div>
        <div class="chat-header-info">
            <div class="chat-header-name">@Model.OtherUserName</div>
            <div class="chat-header-sub">🏠 @Model.PropertyTitle</div>
        </div>
        <div class="chat-status" id="chatStatus">●</div>
    </div>

    <!-- Messages -->
    <div class="chat-messages" id="chatMessages">
        @if (!Model.Messages.Any())
        {
            <div class="chat-empty">
                <div style="font-size:2.5rem;margin-bottom:.5rem;">💬</div>
                <p>Start the conversation!</p>
            </div>
        }
        else
        {
            @foreach (var msg in Model.Messages)
            {
                <div class="msg-wrapper @(msg.IsMine ? "msg-mine" : "msg-theirs")">
                    @if (!msg.IsMine)
                    {
                        <div class="msg-avatar">
                            @(Model.OtherUserName.Length > 0 ? Model.OtherUserName[0].ToString().ToUpper() : "?")
                        </div>
                    }
                    <div class="msg-bubble">
                        <div class="msg-text">@msg.MessageText</div>
                        <div class="msg-meta">
                            @msg.CreatedAt.ToString("HH:mm")
                            @if (msg.IsMine)
                            {
                                <span class="msg-read @(msg.IsRead ? "read" : "")">
                                    @(msg.IsRead ? "✓✓" : "✓")
                                </span>
                            }
                        </div>
                    </div>
                </div>
            }
        }
        <div id="typingIndicator" class="typing-indicator" style="display:none;">
            <div class="msg-wrapper msg-theirs">
                <div class="msg-avatar">
                    @(Model.OtherUserName.Length > 0 ? Model.OtherUserName[0].ToString().ToUpper() : "?")
                </div>
                <div class="msg-bubble typing-bubble">
                    <span></span><span></span><span></span>
                </div>
            </div>
        </div>
        <div id="bottomAnchor"></div>
    </div>

    <!-- Input -->
    <div class="chat-input-bar">
        <input type="text" id="msgInput" class="chat-input"
               placeholder="Type a message…" autocomplete="off" />
        <button id="sendBtn" class="chat-send-btn" title="Send">
            <svg width="20" height="20" viewBox="0 0 24 24" fill="none"
                 stroke="currentColor" stroke-width="2.5">
                <line x1="22" y1="2" x2="11" y2="13" />
                <polygon points="22 2 15 22 11 13 2 9 22 2" />
            </svg>
        </button>
    </div>
</div>

@section HeadStyles {
    <style>
        .chat-page {
            display: flex;
            flex-direction: column;
            height: 100vh;
            padding-top: 68px;
            background: var(--bg-page);
        }

        .chat-header {
            display: flex;
            align-items: center;
            gap: .85rem;
            padding: .9rem 1.5rem;
            background: var(--bg-card);
            border-bottom: 1px solid var(--border-subtle);
            position: sticky;
            top: 68px;
            z-index: 10;
        }

        .chat-back {
            font-size: 1.2rem;
            color: var(--accent-1);
            text-decoration: none;
            font-weight: 700;
        }

        .chat-header-avatar {
            width: 40px;
            height: 40px;
            border-radius: 50%;
            background: var(--gradient-btn);
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: .95rem;
            font-weight: 700;
            color: #fff;
            flex-shrink: 0;
        }

        .chat-header-info {
            flex: 1;
        }

        .chat-header-name {
            font-weight: 700;
            font-size: .95rem;
        }

        .chat-header-sub {
            font-size: .75rem;
            color: var(--text-muted);
        }

        .chat-status {
            color: #43e97b;
            font-size: .6rem;
        }

        .chat-messages {
            flex: 1;
            overflow-y: auto;
            padding: 1.5rem;
            display: flex;
            flex-direction: column;
            gap: .75rem;
            scrollbar-width: thin;
        }

        .chat-empty {
            text-align: center;
            margin: auto;
            color: var(--text-muted);
        }

        .msg-wrapper {
            display: flex;
            align-items: flex-end;
            gap: .5rem;
            max-width: 70%;
        }

        .msg-mine {
            margin-left: auto;
            flex-direction: row-reverse;
        }

        .msg-avatar {
            width: 30px;
            height: 30px;
            border-radius: 50%;
            background: var(--gradient-btn);
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: .72rem;
            font-weight: 700;
            color: #fff;
            flex-shrink: 0;
        }

        .msg-bubble {
            padding: .65rem .9rem;
            border-radius: 18px;
            max-width: 100%;
            word-break: break-word;
        }

        .msg-mine .msg-bubble {
            background: linear-gradient(135deg, #6c63ff, #a78bfa);
            color: #fff;
            border-bottom-right-radius: 4px;
        }

        .msg-theirs .msg-bubble {
            background: var(--bg-card);
            border: 1px solid var(--border-subtle);
            color: var(--text-primary);
            border-bottom-left-radius: 4px;
        }

        .msg-text {
            font-size: .9rem;
            line-height: 1.5;
        }

        .msg-meta {
            font-size: .68rem;
            margin-top: .3rem;
            opacity: .7;
            text-align: right;
            display: flex;
            gap: .3rem;
            justify-content: flex-end;
        }

        .msg-read {
            font-size: .75rem;
        }

            .msg-read.read {
                color: #43e97b;
                opacity: 1;
            }

        .typing-bubble {
            display: flex;
            gap: .3rem;
            align-items: center;
            padding: .75rem 1rem;
        }

            .typing-bubble span {
                width: 8px;
                height: 8px;
                border-radius: 50%;
                background: var(--text-muted);
                animation: typing 1.2s infinite;
            }

                .typing-bubble span:nth-child(2) {
                    animation-delay: .2s;
                }

                .typing-bubble span:nth-child(3) {
                    animation-delay: .4s;
                }

        @@keyframes typing {
            0%, 60%, 100% {
                transform: translateY(0);
            }

            30% {
                transform: translateY(-6px);
            }
        }

        .chat-input-bar {
            display: flex;
            gap: .75rem;
            padding: 1rem 1.5rem;
            background: var(--bg-card);
            border-top: 1px solid var(--border-subtle);
        }

        .chat-input {
            flex: 1;
            background: var(--bg-page);
            border: 1.5px solid var(--border-subtle);
            border-radius: 100px;
            padding: .7rem 1.2rem;
            font-size: .92rem;
            font-family: 'DM Sans', sans-serif;
            color: var(--text-primary);
            outline: none;
            transition: border-color .2s;
        }

            .chat-input:focus {
                border-color: var(--accent-1);
            }

        .chat-send-btn {
            width: 44px;
            height: 44px;
            border-radius: 50%;
            background: var(--gradient-btn);
            border: none;
            cursor: pointer;
            color: #fff;
            display: flex;
            align-items: center;
            justify-content: center;
            transition: transform .2s, box-shadow .2s;
            flex-shrink: 0;
        }

            .chat-send-btn:hover {
                transform: scale(1.08);
                box-shadow: var(--shadow-btn);
            }

        @@media(max-width:600px) {
            .msg-wrapper {
                max-width: 85%;
            }
        }
    </style>
}

@section Scripts {
    <script src="https://cdnjs.cloudflare.com/ajax/libs/microsoft-signalr/7.0.5/signalr.min.js"></script>
    <script>
        const propertyId  = '@Model.PropertyId';
        const otherUserId = '@Model.OtherUserId';
        const currentUserId = '@Model.CurrentUserId';
        const apiBase = "https://localhost:7000";

        const messagesEl = document.getElementById('chatMessages');
        const msgInput   = document.getElementById('msgInput');
        const typingEl   = document.getElementById('typingIndicator');
        const anchor     = document.getElementById('bottomAnchor');

        // ── SignalR connection ──────────────────────────────────────────────
        const connection = new signalR.HubConnectionBuilder()
                    .withUrl(`${apiBase}/hubs/chat`, {
            accessTokenFactory: () => '@Context.Session.GetString("JwtToken")'
        })
            .withAutomaticReconnect()
            .build();

        connection.on('ReceiveMessage', (msg) => {
            appendMessage(msg, msg.senderId === currentUserId);
            scrollToBottom();
            if (msg.senderId !== currentUserId) {
                connection.invoke('MarkAsRead', propertyId, msg.senderId).catch(() => {});
            }
        });

        connection.on('MessagesRead', () => {
            document.querySelectorAll('.msg-read').forEach(el => {
                el.textContent = '✓✓';
                el.classList.add('read');
            });
        });

        connection.on('UserTyping', (userId) => {
            if (userId !== currentUserId) showTyping();
        });

        async function startConnection() {
            try {
                await connection.start();
                await connection.invoke('JoinConversation', propertyId, otherUserId);
                document.getElementById('chatStatus').style.color = '#43e97b';
            } catch (e) {
                console.warn('SignalR connection failed — using REST fallback');
                document.getElementById('chatStatus').style.color = '#ef4444';
            }
        }
        startConnection();

        // ── Send message ────────────────────────────────────────────────────
        async function sendMessage() {
            const text = msgInput.value.trim();
            if (!text) return;
            msgInput.value = '';

            if (connection.state === signalR.HubConnectionState.Connected) {
                await connection.invoke('SendMessage', otherUserId, propertyId, text);
            } else {
                // REST fallback
                await fetch('/Chat/Send', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json', 'RequestVerificationToken': getAntiforgeryToken() },
                    body: JSON.stringify({ receiverId: otherUserId, propertyId, messageText: text })
                });
                appendMessage({ senderName: 'You', messageText: text, createdAt: new Date().toISOString(), isRead: false }, true);
                scrollToBottom();
            }
        }

        document.getElementById('sendBtn').addEventListener('click', sendMessage);
        msgInput.addEventListener('keydown', e => { if (e.key === 'Enter' && !e.shiftKey) { e.preventDefault(); sendMessage(); } });

        // ── Typing indicator ─────────────────────────────────────────────
        let typingTimeout;
        msgInput.addEventListener('input', () => {
            if (connection.state === signalR.HubConnectionState.Connected) {
                connection.invoke('UserTyping', otherUserId).catch(() => {});
            }
            clearTimeout(typingTimeout);
        });

        let typingHideTimeout;
        function showTyping() {
            typingEl.style.display = 'block';
            scrollToBottom();
            clearTimeout(typingHideTimeout);
            typingHideTimeout = setTimeout(() => { typingEl.style.display = 'none'; }, 2500);
        }

        // ── Append message bubble ────────────────────────────────────────
        function appendMessage(msg, isMine) {
            const wrapper = document.createElement('div');
            wrapper.className = `msg-wrapper ${isMine ? 'msg-mine' : 'msg-theirs'}`;

            const time = new Date(msg.createdAt).toLocaleTimeString([], { hour: '2-digit', minute: '2-digit' });
            const readMark = isMine ? `<span class="msg-read ${msg.isRead ? 'read' : ''}">${msg.isRead ? '✓✓' : '✓'}</span>` : '';

            wrapper.innerHTML = `
                ${!isMine ? `<div class="msg-avatar">${(msg.senderName || '?')[0].toUpperCase()}</div>` : ''}
                <div class="msg-bubble">
                    <div class="msg-text">${escapeHtml(msg.messageText)}</div>
                    <div class="msg-meta">${time} ${readMark}</div>
                </div>
            `;

            messagesEl.insertBefore(wrapper, anchor);
        }

        function escapeHtml(text) {
            return text.replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;');
        }

        function scrollToBottom() {
            anchor.scrollIntoView({ behavior: 'smooth' });
        }

        function getAntiforgeryToken() {
            return document.querySelector('input[name="__RequestVerificationToken"]')?.value || '';
        }

        // Initial scroll
        scrollToBottom();
    </script>
}