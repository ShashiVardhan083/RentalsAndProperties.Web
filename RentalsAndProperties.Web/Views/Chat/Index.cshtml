@model List<RentalsAndProperties.Web.ViewModels.Chat.ConversationListViewModel>
@{
    ViewData["Title"] = "Messages";
}

<div class="dashboard-page">
    <div class="dashboard-header">
        <div class="dashboard-header-inner">
            <div>
                <h1 class="dashboard-title">💬 Messages</h1>
                <p class="dashboard-subtitle">@Model.Count conversation@(Model.Count != 1 ? "s" : "")</p>
            </div>
        </div>
    </div>
    <div class="dashboard-body">
        @if (!Model.Any())
        {
            <div class="empty-state">
                <div class="empty-icon">💬</div>
                <h3>No Conversations Yet</h3>
                <p>Start chatting by visiting a property and messaging the owner.</p>
                <a href="/Property/Browse" class="btn btn-primary mt-3">Browse Properties →</a>
            </div>
        }
        else
        {
            <div class="conv-list">
                @foreach (var c in Model)
                {
                    <a href="/Chat/Conversation?propertyId=@c.PropertyId&otherUserId=@c.OtherUserId&otherUserName=@Uri.EscapeDataString(c.OtherUserName)&propertyTitle=@Uri.EscapeDataString(c.PropertyTitle)"
                       class="conv-item">
                        <div class="conv-avatar">
                            @(c.OtherUserName.Length > 0 ? c.OtherUserName[0].ToString().ToUpper() : "?")
                        </div>
                        <div class="conv-body">
                            <div class="conv-header">
                                <span class="conv-name">@c.OtherUserName</span>
                                <span class="conv-time">@c.LastMessageAt.ToString("MMM dd")</span>
                            </div>
                            <div class="conv-property">🏠 @c.PropertyTitle</div>
                            <div class="conv-preview">@c.LastMessage</div>
                        </div>
                        @if (c.UnreadCount > 0)
                        {
                            <div class="conv-badge">@c.UnreadCount</div>
                        }
                    </a>
                }
            </div>
        }
    </div>
</div>

@section HeadStyles {
    <style>
        .dashboard-page {
            padding-top: 68px;
            min-height: 100vh;
        }

        .dashboard-header {
            background: var(--gradient-hero);
            border-bottom: 1px solid var(--border-subtle);
            padding: 2.5rem 2rem;
        }

        .dashboard-header-inner {
            max-width: 1280px;
            margin: 0 auto;
        }

        .dashboard-title {
            font-size: 1.75rem;
            font-weight: 800;
        }

        .dashboard-subtitle {
            color: var(--text-secondary);
            margin-top: .25rem;
        }

        .dashboard-body {
            max-width: 700px;
            margin: 0 auto;
            padding: 2rem;
        }

        .conv-list {
            display: flex;
            flex-direction: column;
            gap: .75rem;
        }

        .conv-item {
            display: flex;
            align-items: center;
            gap: 1rem;
            padding: 1.1rem 1.25rem;
            background: var(--bg-card);
            border: 1px solid var(--border-subtle);
            border-radius: var(--radius-lg);
            text-decoration: none;
            color: inherit;
            transition: border-color .2s,transform .2s;
        }

            .conv-item:hover {
                border-color: var(--border-accent);
                transform: translateY(-2px);
            }

        .conv-avatar {
            width: 46px;
            height: 46px;
            border-radius: 50%;
            background: var(--gradient-btn);
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 1.1rem;
            font-weight: 700;
            color: #fff;
            flex-shrink: 0;
        }

        .conv-body {
            flex: 1;
            min-width: 0;
        }

        .conv-header {
            display: flex;
            justify-content: space-between;
            align-items: center;
            margin-bottom: .2rem;
        }

        .conv-name {
            font-weight: 700;
            font-size: .95rem;
        }

        .conv-time {
            font-size: .75rem;
            color: var(--text-muted);
        }

        .conv-property {
            font-size: .75rem;
            color: var(--accent-1);
            margin-bottom: .2rem;
        }

        .conv-preview {
            font-size: .83rem;
            color: var(--text-secondary);
            white-space: nowrap;
            overflow: hidden;
            text-overflow: ellipsis;
        }

        .conv-badge {
            width: 22px;
            height: 22px;
            background: var(--accent-1);
            color: #fff;
            border-radius: 50%;
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: .72rem;
            font-weight: 700;
            flex-shrink: 0;
        }

        .empty-state {
            text-align: center;
            padding: 5rem 2rem;
        }

        .empty-icon {
            font-size: 4rem;
            margin-bottom: 1rem;
        }

        .empty-state h3 {
            font-size: 1.5rem;
            margin-bottom: .5rem;
        }
    </style>
}