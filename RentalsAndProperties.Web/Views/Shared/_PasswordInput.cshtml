@{
    var fieldId = ViewData["FieldId"]?.ToString() ?? "Password";
    var fieldName = ViewData["FieldName"]?.ToString() ?? "Password";
    var label = ViewData["Label"]?.ToString() ?? "Password";
    var showStrength = (bool)(ViewData["ShowStrength"] ?? false);
}


<div class="form-group" id="@(fieldId)Group">
    <div class="form-control-wrapper" style="position:relative;">
        <label for="@fieldId" class="form-label-static">@label</label>

        <input type="password"
               id="@fieldId"
               name="@fieldName"
               class="form-control"
               placeholder=" "
               autocomplete="current-password"
               required
               data-required="true"
               data-required-msg="@label is required." />
        <button type="button"
                class="toggle-password"
                data-target="@fieldId"
                title="Show/hide password"
                aria-label="Toggle password visibility"
                style="position:absolute;right:.75rem;top:50%;transform:translateY(-50%);
                       background:none;border:none;cursor:pointer;color:var(--text-muted);
                       padding:0;display:flex;align-items:center;z-index:2;">
            <svg class="eye-icon eye-closed" width="18" height="18" viewBox="0 0 24 24"
                 fill="none" stroke="currentColor" stroke-width="2">
                <path d="M17.94 17.94A10.07 10.07 0 0112 20c-7 0-11-8-11-8a18.45 18.45 0 015.06-5.94" />
                <path d="M9.9 4.24A9.12 9.12 0 0112 4c7 0 11 8 11 8a18.5 18.5 0 01-2.16 3.19" />
                <line x1="1" y1="1" x2="23" y2="23" />
            </svg>
            <svg class="eye-icon eye-open" width="18" height="18" viewBox="0 0 24 24"
                 fill="none" stroke="currentColor" stroke-width="2" style="display:none;">
                <path d="M1 12s4-8 11-8 11 8 11 8-4 8-11 8-11-8-11-8z" />
                <circle cx="12" cy="12" r="3" />
            </svg>
        </button>
    </div>
    <span class="invalid-feedback" id="@(fieldId)Error"></span>
    @if (showStrength)
    {
        <div class="strength-bar mt-1" id="@(fieldId)StrengthBar">
            <div class="strength-segment"></div>
            <div class="strength-segment"></div>
            <div class="strength-segment"></div>
            <div class="strength-segment"></div>
            <div class="strength-segment"></div>
        </div>
        <div class="strength-label text-muted" id="@(fieldId)StrengthLabel"></div>
    }
</div>

@if (showStrength)
{
    <script>
        document.addEventListener('DOMContentLoaded', function () {
            initPasswordStrength('@fieldId', '@(fieldId)StrengthBar', '@(fieldId)StrengthLabel');
        });
    </script>
}