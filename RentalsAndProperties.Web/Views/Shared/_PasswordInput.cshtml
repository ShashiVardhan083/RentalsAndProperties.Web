@* _PasswordInput.cshtml – Reusable password field with strength + toggle *@
@{
    var fieldId = ViewData["FieldId"]?.ToString() ?? "Password";
    var fieldName = ViewData["FieldName"]?.ToString() ?? "Password";
    var label = ViewData["Label"]?.ToString() ?? "Password";
    var showStrength = (bool)(ViewData["ShowStrength"] ?? false);
    var placeholder = ViewData["Placeholder"]?.ToString() ?? "Enter your password";
}
<div class="form-group" id="@(fieldId)Group">
    <label for="@fieldId" class="form-label-static">@label</label>
    <div class="form-control-wrapper">
        <input type="password"
               id="@fieldId"
               name="@fieldName"
               class="form-control"
               placeholder="@placeholder"
               autocomplete="@(label.Contains("Confirm") ? "new-password" : "current-password")"
               required
               data-required="true"
               data-required-msg="@label is required." />
        <button type="button"
                class="toggle-password"
                data-target="@fieldId"
                title="Show/hide password"
                aria-label="Toggle password visibility">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none"
                 stroke="currentColor" stroke-width="2">
                <path d="M1 12s4-8 11-8 11 8 11 8-4 8-11 8-11-8-11-8z" />
                <circle cx="12" cy="12" r="3" />
            </svg>
        </button>
    </div>
    <span class="invalid-feedback" id="@(fieldId)Error"></span>
    @if (showStrength)
    {
        <div class="strength-bar mt-1" id="@(fieldId)StrengthBar">
            <div class="strength-segment"></div>
            <div class="strength-segment"></div>
            <div class="strength-segment"></div>
            <div class="strength-segment"></div>
            <div class="strength-segment"></div>
        </div>
        <div class="strength-label text-muted" id="@(fieldId)StrengthLabel"></div>
    }
</div>
@if (showStrength)
{
    <script>
        document.addEventListener('DOMContentLoaded', function () {
            initPasswordStrength('@fieldId', '@(fieldId)StrengthBar', '@(fieldId)StrengthLabel');
        });
    </script>
}
