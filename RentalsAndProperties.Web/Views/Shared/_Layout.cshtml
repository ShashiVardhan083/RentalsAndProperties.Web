@{
    var isAuthenticated = User?.Identity?.IsAuthenticated ?? false;
    var fullName = User?.Identity?.Name ?? "";

    var roles = new List<string>();
    if (User?.Identity?.IsAuthenticated == true)
    {
        roles = User.Claims
            .Where(c => c.Type == System.Security.Claims.ClaimTypes.Role)
            .Select(c => c.Value)
            .ToList();
    }

    var isOwnerOrAdmin = roles.Contains("Owner") || roles.Contains("Admin");
    var isAdmin = roles.Contains("Admin");
    var initials = string.IsNullOrEmpty(fullName) ? "?" :
        string.Join("", fullName.Split(' ', StringSplitOptions.RemoveEmptyEntries) //["", "", "Shashi", "", "", "Vardhan", "", ""]
            .Take(2).Select(w => w[0].ToString().ToUpper()));

    var welcomeMsg = TempData["WelcomeMessage"]?.ToString();
    var successMsg = TempData["ToastSuccess"]?.ToString();

    var currentPath = Context.Request.Path.ToString();
}

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>@(ViewData["Title"] != null ? $"{ViewData["Title"]} – " : "")RentalsAndProperties</title>
    <meta name="description" content="Find your perfect rental property with RentalsAndProperties.">

    <style>
        :root {
            --bg-main: #0f172a;
            --bg-card: #1e293b;
            --text-primary: #e2e8f0;
            --text-muted: #94a3b8;
            --accent-1: #6366f1;
            --border-subtle: #334155;
            --radius-md: 10px;
        }

        body {
            margin: 0;
            font-family: "Segoe UI", sans-serif;
            background: var(--bg-main);
            color: var(--text-primary);
        }

        /* NAVBAR */
         .navbar {
            display: flex;
            justify-content: space-between;
            align-items: center; @*vertical*@
            padding: 0.8rem 2rem;
            background: var(--bg-card);
            border-bottom: 1px solid var(--border-subtle);
            position: sticky;
            top: 0;
            z-index: 100;
        } 

        .navbar-brand {
            font-weight: 700;
            text-decoration: none;
            color: var(--text-primary);
            font-size: 1.2rem;
        }

        .navbar-nav {
            display: flex;
            list-style: none;
            gap: 1rem;
            align-items: center;
            margin: 0;
            padding: 0;
        }

         .nav-link {
            text-decoration: none;
            color: var(--text-muted);
            font-weight: 500;
            padding: 0.4rem 0.6rem;
            border-radius: var(--radius-md);
            transition: 0.2s;
        }

           .nav-link:hover {
                color: var(--text-primary);
                background: rgba(255,255,255,0.05);
            }

            .nav-link.active {
                color: white;
                background: var(--accent-1);
            }

        /* BUTTON */
        .btn-nav-auth {
            background: var(--accent-1);
            color: white;
            padding: 0.5rem 0.9rem;
            border-radius: var(--radius-md);
            text-decoration: none;
            display: flex;
            align-items: center;
            gap: 0.3rem;
            font-weight: 600;
        }

        .btn-nav-auth:hover {
            background: #4f46e5;
        }

        /* PROFILE */
        .profile-dropdown {
            position: relative;
        }

        .profile-trigger {
            display: flex;
            align-items: center;
            gap: 0.4rem;
            cursor: pointer;
        }

        .profile-avatar {
            width: 32px;
            height: 32px;
            background: var(--accent-1);
            border-radius: 50%;
            display: flex;
            align-items: center;
            justify-content: center;
            font-weight: bold;
        }

        .profile-name {
            font-size: 0.9rem;
        }

        /* DROPDOWN */
        .dropdown-menu {
            position: absolute;
            right: 0;
            top: 110%;
            background: var(--bg-card);
            border: 1px solid var(--border-subtle);
            border-radius: var(--radius-md);
            min-width: 180px;
            display: none;
            flex-direction: column;
            box-shadow: 0 10px 20px rgba(0,0,0,0.3);
            z-index: 200;
        }

            .dropdown-menu.show {
                display: flex;
            }

        .dropdown-item {
            padding: 0.6rem 0.8rem;
            text-decoration: none;
            color: var(--text-primary);
            background: none;
            border: none;
            text-align: left;
            cursor: pointer;
        }

            .dropdown-item:hover {
                background: rgba(255,255,255,0.05);
            }

            .dropdown-item.danger {
                color: #ef4444;
            }

        .dropdown-divider {
            height: 1px;
            background: var(--border-subtle);
            margin: 0.4rem 0;
        }

        main {
            padding: 1rem 2rem;
        } 
    </style>

    @RenderSection("HeadStyles", required: false) @*if any page contains HeadStyles render it here*@
</head>

<body data-authenticated="@(isAuthenticated ? "true" : "false")">

    @if (!string.IsNullOrEmpty(welcomeMsg))
    {
        <div id="welcomeMessage" data-message="@welcomeMsg" style="display:none;"></div>
    }

    @if (!string.IsNullOrEmpty(successMsg))
    {
        <div id="toastSuccess" data-message="@successMsg" style="display:none;"></div>
    }

    <!-- Navbar -->
    <nav class="navbar" role="navigation" aria-label="Main navigation">

        <a asp-controller="Home" asp-action="Index" class="navbar-brand" aria-label="RentalsAndProperties Home">
            @*ARIA (Accessible Rich Internet Applications)
                It tells screen readers:

                “This is what this element means”*@
            🏠 RentalsAndProperties
        </a>

        <ul class="navbar-nav" role="list"> @*role is an ARIA*@

            <li>
                <a asp-controller="Home" asp-action="Index"
                   class="nav-link @(currentPath == "/" ? "active" : "")">
                    Home
                </a>
            </li>

            <li>
                <a asp-controller="Property" asp-action="Browse"
                   class="nav-link @(currentPath.StartsWith("/Property/Browse") ? "active" : "")">
                    Browse
                </a>
            </li>

            @if (isAuthenticated)
            {
                <li>
                    <a asp-controller="Transaction" asp-action="MyTransactions"
                       class="nav-link @(currentPath.StartsWith("/Transaction") ? "active" : "")">
                        My Deals
                    </a>
                </li>
                <li>
                    <a asp-controller="Report" asp-action="MyReports"
                       class="nav-link @(currentPath.StartsWith("/Report") ? "active" : "")">
                        My Reports
                    </a>
                </li>

                @if (isOwnerOrAdmin)
                {
                    <li>
                        <a asp-controller="Property" asp-action="Dashboard"
                           class="nav-link @(currentPath.StartsWith("/Property/Dashboard") || currentPath.StartsWith("/Property/Create") || currentPath.StartsWith("/Property/Edit") ? "active" : "")">
                            My Listings
                        </a>
                    </li>
                }

                @if (isAdmin)
                {
                    <li>
                        <a asp-controller="Admin" asp-action="Index"
                           class="nav-link @(currentPath.StartsWith("/Admin/Index") ? "active" : "")"
                           style="color:#f59e0b;">
                            🛡 Property Approvals
                        </a>
                    </li>

                    <li>
                        <a asp-controller="Admin" asp-action="Dashboard"
                           class="nav-link @(currentPath == "/Admin/Dashboard" ? "active" : "")"
                           style="color:#a78bfa;">
                            📊 Analytics
                        </a>
                    </li>

                    <li>
                        <a asp-controller="Admin" asp-action="Reports"
                           class="nav-link @(currentPath.StartsWith("/Admin/Reports") ? "active" : "")"
                           style="color:#ef4444;">
                            🚩 Reports
                        </a>
                    </li>
                }

                <!-- Profile Dropdown -->
                <li>
                    <div class="profile-dropdown" id="profileDropdown">
                        <div class="profile-trigger" role="button" aria-haspopup="true"
                             aria-expanded="false" tabindex="0">

                            <div class="profile-avatar" aria-hidden="true">@initials</div> @*Screen readers can not read aria-hidden*@
                            <span class="profile-name">@fullName</span>

                            <svg width="14" height="14" viewBox="0 0 24 24" fill="none"
                                 @*SVG = Scalable Vector Graphics
                                  It’s a way to draw graphics using code (not images)*@
                                 stroke="currentColor" stroke-width="2.5" aria-hidden="true">
                                <polyline points="6 9 12 15 18 9" />
                            </svg>
                        </div>

                        <div class="dropdown-menu" role="menu">

                            <div style="padding:.5rem .75rem ;font-size:.82rem;font-weight:600;color:var(--text-primary);">
                                @fullName
                            </div>

                            <div style="padding:.1rem .75rem .4rem;font-size:.72rem;color:var(--text-muted);">
                                @string.Join(", ", roles)
                            </div>

                            <div class="dropdown-divider"></div>

                            <form asp-action="Logout" asp-controller="Auth" method="post" style="margin:0;">
                                @Html.AntiForgeryToken()
                                <button type="submit" class="dropdown-item danger" role="menuitem">
                                    <span>🚪</span> Sign Out
                                </button>
                            </form>

                        </div>
                    </div>
                </li>
            }
            else
            {
                <li>
                    <a asp-controller="Auth" asp-action="Login" class="nav-link">
                        Sign In
                    </a>
                </li>

                <li>
                    <a asp-controller="Auth" asp-action="Register" class="btn-nav-auth">
                        <svg width="14" height="14" viewBox="0 0 24 24" fill="none"
                             stroke="currentColor" stroke-width="2.5">
                            <path d="M16 21
                                     v-2
                                     a4 4 0 00-4-4
                                     H6a4 4 0 00-4 4
                                     v2" />
                            <circle cx="9" cy="7" r="4" />
                            <line x1="19" y1="8" x2="19" y2="14" />
                            <line x1="22" y1="11" x2="16" y2="11" />
                        </svg>
                        Get Started
                    </a>
                </li>
            }

        </ul>
    </nav>

    <main id="main-content">
        @RenderBody()
    </main>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/jquery/3.7.1/jquery.min.js"></script> @*These 3 scripts enable automatic validation from ViewModel*@
    <script src="https://cdnjs.cloudflare.com/ajax/libs/jquery-validate/1.19.5/jquery.validate.min.js"></script>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/jquery-validation-unobtrusive/4.0.0/jquery.validate.unobtrusive.min.js"></script>
    <script>
        const Toast = {
            show(msg, color) {
                const el = document.createElement('div');
                el.textContent = msg;
                Object.assign(el.style, {
                    position: 'fixed', bottom: '1.5rem', right: '1.5rem',
                    background: color, color: '#fff', padding: '0.8rem 1.2rem',
                    borderRadius: '8px', zIndex: 9999, fontSize: '0.9rem',
                    boxShadow: '0 4px 12px rgba(0,0,0,0.3)'
                });
                document.body.appendChild(el);
                setTimeout(() => el.remove(), 3500);
            },
            success(msg) { this.show(msg, '#10b981'); },
            error(msg)   { this.show(msg, '#ef4444'); }
        };

        const Validator = {
            attachLiveValidation(form) {
                form.querySelectorAll('[data-required]').forEach(field => {
                    field.addEventListener('blur', () => {
                        const msg = field.dataset.requiredMsg || 'This field is required.';
                        const feedback = field.nextElementSibling;
                        if (!field.value.trim()) {
                            field.style.borderColor = '#ef4444';
                            if (feedback) feedback.textContent = msg;
                        } else {
                            field.style.borderColor = '';
                            if (feedback) feedback.textContent = '';
                        }
                    });
                });
            }
        };
    </script>
    @RenderSection("Scripts", required: false)

    <script>
        document.addEventListener('DOMContentLoaded', function () {

            // Toast messages
            const s = document.getElementById('toastSuccess');
            if (s) {
                Toast.success(s.dataset.message);
                s.remove();
            }

            const w = document.getElementById('welcomeMessage');
            if (w) {
                Toast.success(w.dataset.message);
                w.remove();
            }

            // Profile dropdown toggle
            const dropdown = document.getElementById('profileDropdown');

            if (dropdown) {
                const trigger = dropdown.querySelector('.profile-trigger');
                const menu = dropdown.querySelector('.dropdown-menu');

                trigger.addEventListener('click', function (e) {

                    e.stopPropagation();
                    document.querySelectorAll('.dropdown-menu').forEach(m => {
                        if (m !== menu) m.classList.remove('show');
                    });
                    menu.classList.toggle('show');
                });

                // Close on outside click
                document.addEventListener('click', function () {
                    menu.classList.remove('show');
                });
            }
        });
        
    </script>
   
</body>
</html>