@model string
@{
    var fieldId = ViewData["FieldId"]?.ToString() ?? "PhoneNumber";
    var fieldName = ViewData["FieldName"]?.ToString() ?? "PhoneNumber";
    var label = ViewData["Label"]?.ToString() ?? "Phone Number";
    var placeholder = ViewData["Placeholder"]?.ToString() ?? " ";
}

<div class="form-group" id="@(fieldId)Group">
    <div class="form-control-wrapper">
        <label for="@fieldId" class="form-label">@label</label>
        <input type="tel"
               id="@fieldId"
               name="@fieldName"
               class="form-control @(!string.IsNullOrEmpty(Model) ? "has-value" : "")"
               placeholder=" "
               value="@Model"
               autocomplete="username"
               inputmode="tel"
               required
               data-required="true"
               data-required-msg="Phone number is required."
               maxlength="16" />
        
    </div>
    <span class="invalid-feedback" id="@(fieldId)Error"></span>
</div>