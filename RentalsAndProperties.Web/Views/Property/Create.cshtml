@model RentalsAndProperties.Web.Models.ViewModels.CreatePropertyViewModel
@using RentalsAndProperties.Web.Models
@{
    ViewData["Title"] = "Add Property";
    var propertyTypes = (PropertyTypeWeb[])ViewBag.PropertyTypes;
    var listingTypes = (ListingTypeWeb[])ViewBag.ListingTypes;
    var bhkTypes = (BHKTypeWeb[])ViewBag.BHKTypes;
    var furnishingTypes = (FurnishingTypeWeb[])ViewBag.FurnishingTypes;
}

<div class="form-page">
    <div class="form-page-header">
        <div class="form-page-header-inner">
            <a href="/Property/Dashboard" class="back-link">← My Properties</a>
            <h1 class="form-page-title">List a New Property</h1>
            <p class="form-page-subtitle">Fill in the details below. Your property will go live after admin approval.</p>
        </div>
    </div>

    <div class="form-page-body">
        <form asp-action="Create" asp-controller="Property" method="post"
              enctype="multipart/form-data" id="propertyForm" novalidate>
            @Html.AntiForgeryToken()

            @if (!ViewData.ModelState.IsValid)
            {
                <div class="alert alert-error">
                    <span>⚠</span>
                    <div>
                        @foreach (var error in ViewData.ModelState.Values.SelectMany(v => v.Errors))
                        {
                            <div>@error.ErrorMessage</div>
                        }
                    </div>
                </div>
            }

            <div class="form-grid">

                <!-- Basic Info -->
                <div class="form-section">
                    <h2 class="form-section-title">📋 Basic Information</h2>

                    <div class="form-group">
                        <label asp-for="Title" class="form-label">Property Title</label>
                        <input asp-for="Title" class="form-control" placeholder=" " required data-required="true" />
                        <span asp-validation-for="Title" class="invalid-feedback"></span>
                    </div>

                    <div class="form-group">
                        <label asp-for="Description" class="form-label">Description</label>
                        <textarea asp-for="Description" class="form-control textarea" placeholder=" "
                                  required data-required="true" rows="4"></textarea>
                        <span asp-validation-for="Description" class="invalid-feedback"></span>
                    </div>

                    <div class="form-row-2">
                        <div class="form-group">
                            <label asp-for="City" class="form-label">City</label>
                            <input asp-for="City" class="form-control" placeholder=" " required data-required="true" />
                            <span asp-validation-for="City" class="invalid-feedback"></span>
                        </div>
                        <div class="form-group">
                            <label asp-for="Address" class="form-label">Full Address</label>
                            <input asp-for="Address" class="form-control" placeholder=" " required data-required="true" />
                            <span asp-validation-for="Address" class="invalid-feedback"></span>
                        </div>
                    </div>
                </div>

                <!-- Pricing -->
                <div class="form-section">
                    <h2 class="form-section-title">💰 Pricing</h2>
                    <div class="form-row-2">
                        <div class="form-group">
                            <label asp-for="Price" class="form-label" style="left:2.5rem;">Price</label>
                            <div class="input-prefix-wrap">
                                <span class="input-prefix">₹</span>
                                <input asp-for="Price" class="form-control has-prefix" type="number"
                                       placeholder=" " required data-required="true" min="1" />
                            </div>
                            <span asp-validation-for="Price" class="invalid-feedback"></span>
                        </div>
                        <div class="form-group">
                            <label asp-for="SecurityDeposit" class="form-label" style="left:2.5rem;">Security Deposit</label>
                            <div class="input-prefix-wrap">
                                <span class="input-prefix">₹</span>
                                <input asp-for="SecurityDeposit" class="form-control has-prefix" type="number"
                                       placeholder=" " min="0" />
                            </div>
                        </div>
                    </div>

                    <div class="form-row-2">
                        <div class="form-group">
                            <label asp-for="ListingType" class="form-label form-label-select">Listing Type</label>
                            <select asp-for="ListingType" class="form-control form-select" required>
                                <option value="">Select type…</option>
                                @foreach (var lt in listingTypes)
                                {
                                    <option value="@((int)lt)">@lt</option>
                                }
                            </select>
                            <span asp-validation-for="ListingType" class="invalid-feedback"></span>
                        </div>
                        <div class="form-group">
                            <label asp-for="AvailableFrom" class="form-label form-label-select">Available From</label>
                            <input asp-for="AvailableFrom" class="form-control" type="date" required
                                   min="@DateTime.Today.ToString("yyyy-MM-dd")" />
                            <span asp-validation-for="AvailableFrom" class="invalid-feedback"></span>
                        </div>
                    </div>
                </div>

                <!-- Property Details -->
                <div class="form-section">
                    <h2 class="form-section-title">🏠 Property Details</h2>
                    <div class="form-row-3">
                        <div class="form-group">

                            <label asp-for="PropertyType" class="form-label form-label-select">Property Type</label>
                            <select asp-for="PropertyType" class="form-control form-select" required>
                                <option value="">Select…</option>
                                @foreach (var pt in propertyTypes)
                                {
                                    <option value="@((int)pt)">@pt</option>
                                }
                            </select>
                            <span asp-validation-for="PropertyType" class="invalid-feedback"></span>
                        </div>
                        <div class="form-group">

                            <label asp-for="BHKType" class="form-label form-label-select">BHK Type</label>
                            <select asp-for="BHKType" class="form-control form-select" required>
                                <option value="">Select…</option>
                                @foreach (var bt in bhkTypes)
                                {
                                    <option value="@((int)bt)">@BHKLabels.Get(bt)</option>
                                }
                            </select>
                            <span asp-validation-for="BHKType" class="invalid-feedback"></span>
                        </div>
                        <div class="form-group">

                            <label asp-for="FurnishingType" class="form-label form-label-select">Furnishing</label>
                            <select asp-for="FurnishingType" class="form-control form-select" required>
                                <option value="">Select…</option>
                                @foreach (var ft in furnishingTypes)
                                {
                                    <option value="@((int)ft)">@ft</option>
                                }
                            </select>
                            <span asp-validation-for="FurnishingType" class="invalid-feedback"></span>
                        </div>
                    </div>

                    <div class="form-row-3">
                        <div class="form-group">
                            <label asp-for="Bedrooms" class="form-label">Bedrooms</label>
                            <input asp-for="Bedrooms" class="form-control" type="number"
                                   placeholder=" " min="0" max="20" required />
                        </div>
                        <div class="form-group">
                            <label asp-for="Bathrooms" class="form-label">Bathrooms</label>
                            <input asp-for="Bathrooms" class="form-control" type="number"
                                   placeholder=" " min="0" max="20" required />
                        </div>
                        <div class="form-group">

                            <label asp-for="SquareFeet" class="form-label">Area (sq.ft)</label>
                            <input asp-for="SquareFeet" class="form-control" type="number"
                                   placeholder=" " min="10" required />
                        </div>
                    </div>
                </div>

                <!-- Images -->
                <div class="form-section">
                    <h2 class="form-section-title">📸 Property Images</h2>
                    <p class="form-hint">Upload up to 5 images. First image will be the primary photo. JPG/PNG/WebP, max 5MB each.</p>

                    <div class="image-upload-zone" id="uploadZone">
                        <input type="file" asp-for="Images" id="imageInput"
                               accept=".jpg,.jpeg,.png,.webp" multiple class="file-input-hidden" />
                        <label for="imageInput" class="upload-label">
                            <div class="upload-icon">📁</div>
                            <div class="upload-text"><strong>Click to upload</strong> or drag &amp; drop</div>
                            <div class="upload-hint">JPG, PNG, WebP · Max 5MB each</div>
                        </label>
                    </div>

                    <div class="image-preview-grid" id="imagePreview"></div>
                    <span asp-validation-for="Images" class="invalid-feedback"></span>
                </div>
            </div>

            <div class="form-submit-bar">
                <a href="/Property/Dashboard" class="btn btn-secondary">Cancel</a>
                <button type="submit" class="btn btn-primary btn-lg" id="submitBtn">
                    <span class="btn-text">Submit for Approval →</span>
                    <span class="btn-spinner"></span>
                </button>
            </div>
        </form>
    </div>
</div>

@section Scripts {
    <script>
        document.addEventListener('DOMContentLoaded', function () {
            const form      = document.getElementById('propertyForm');
            const submitBtn = document.getElementById('submitBtn');
            const input     = document.getElementById('imageInput');
            const preview   = document.getElementById('imagePreview');
            const zone      = document.getElementById('uploadZone');
            let selectedFiles = [];

            input.addEventListener('change', () => handleFiles(input.files));
            zone.addEventListener('dragover', e => { e.preventDefault(); zone.classList.add('drag-over'); });
            zone.addEventListener('dragleave', () => zone.classList.remove('drag-over'));
            zone.addEventListener('drop', e => {
                e.preventDefault(); zone.classList.remove('drag-over');
                handleFiles(e.dataTransfer.files);
            });

            function handleFiles(files) {
                const allowed = ['.jpg','.jpeg','.png','.webp'];
                Array.from(files).forEach(file => {
                    if (selectedFiles.length >= 5) { Toast.error('Maximum 5 images allowed.'); return; }
                    const ext = '.' + file.name.split('.').pop().toLowerCase();
                    if (!allowed.includes(ext)) { Toast.error(file.name + ': Invalid format.'); return; }
                    if (file.size > 5 * 1024 * 1024) { Toast.error(file.name + ': Exceeds 5MB.'); return; }
                    selectedFiles.push(file);
                });
                rebuildPreview(); syncFiles();
            }

            function rebuildPreview() {
                preview.innerHTML = '';
                selectedFiles.forEach((file, i) => {
                    const r = new FileReader();
                    r.onload = e => {
                        const item = document.createElement('div');
                        item.className = 'preview-item';
                        item.innerHTML = `<img src="${e.target.result}" alt="preview" />
                            ${i === 0 ? '<div class="preview-primary-badge">Primary</div>' : ''}
                            <button type="button" class="preview-remove" data-i="${i}">&#x2715;</button>`;
                        item.querySelector('.preview-remove').addEventListener('click', () => {
                            selectedFiles.splice(i, 1); rebuildPreview(); syncFiles();
                        });
                        preview.appendChild(item);
                    };
                    r.readAsDataURL(file);
                });
            }

            function syncFiles() {
                const dt = new DataTransfer();
                selectedFiles.forEach(f => dt.items.add(f));
                input.files = dt.files;
            }

            form.addEventListener('submit', function(e) {
                const inputs = form.querySelectorAll('.form-control[required], .form-select[required]');
                let valid = true;
                inputs.forEach(inp => {
                    if (!inp.value || inp.value === '0') {
                        inp.classList.add('is-invalid'); valid = false;
                    } else { inp.classList.remove('is-invalid'); }
                });
                if (!valid) { e.preventDefault(); Toast.error('Please fill in all required fields.'); return; }
                setButtonLoading(submitBtn, true);
            });

            // Select / number floating labels
            document.querySelectorAll('.form-control, .form-select').forEach(el => {
                const update = () => el.classList.toggle('has-value', el.value !== '');
                el.addEventListener('change', update); el.addEventListener('input', update); update();
            });
        });
    </script>
}