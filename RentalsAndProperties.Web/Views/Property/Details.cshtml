@model RentalsAndProperties.Web.ViewModels.Property.PropertyDetailViewModel

@{
    ViewData["Title"] = Model.Title;
}

@if (Model == null)
{
    <div class="text-center mt-5">
        <h2>Property not found</h2>
        <a asp-controller="Property" asp-action="Browse" class="btn btn-primary">
            Browse Properties
        </a>
    </div>
    return;
}

<div class="container mt-4">

    <div class="mb-3">
        <h2>@Model.Title</h2>
        <h4>
            ₹@Model.Price.ToString("N0")
            @if (Model.ListingType == "Rent")
            {
                <span>/month</span>
            }
        </h4>
        <p>@Model.City, @Model.Address</p>
    </div>

    <div class="mb-4">

        @if (Model.AllImageUrls.Any())
        {
            <img id="mainImg"
                 src="@Model.PrimaryImageUrl"
                 class="main-image img-fluid rounded"
                 style="width:100%; object-fit:contain;" />

            <div class="mt-2 d-flex flex-wrap gap-2">
                @foreach (var img in Model.AllImageUrls)
                {
                    <img src="@img"
                         class="thumbnail"
                         style="width:80px;height:60px;object-fit:cover;cursor:pointer;" />
                }
            </div>
        }
        else
        {
            <div class="text-muted">No images available</div>
        }

    </div>

    <div class="card mb-4">
        <div class="card-body">
            <h5>Description</h5>
            <p>@Model.Description</p>
        </div>
    </div>

    <div class="card mb-4">
        <div class="card-body">
            <h5>Property Details</h5>

            <div class="row">

                <div class="col-md-4"><strong>Bedrooms:</strong> @Model.Bedrooms</div>
                <div class="col-md-4"><strong>Bathrooms:</strong> @Model.Bathrooms</div>
                <div class="col-md-4"><strong>Area:</strong> @Model.SquareFeet sq.ft</div>

                <div class="col-md-4"><strong>Type:</strong> @Model.PropertyType</div>
                <div class="col-md-4"><strong>BHK:</strong> @Model.BHKType</div>
                <div class="col-md-4"><strong>Furnishing:</strong> @Model.FurnishingType</div>

                <div class="col-md-4">
                    <strong>Available From:</strong>
                    @Model.AvailableFrom.ToString("dd MMM yyyy")
                </div>

                @if (Model.SecurityDeposit.HasValue)
                {
                    <div class="col-md-4">
                        <strong>Deposit:</strong> ₹@Model.SecurityDeposit.Value.ToString("N0")
                    </div>
                }

                <div class="col-md-4"><strong>Status:</strong> @Model.Status</div>

            </div>
        </div>
    </div>

    <div class="card mb-4">
        <div class="card-body">
            <h5>Owner Details</h5>

            <p><strong>Name:</strong> @Model.OwnerName</p>
            <p><strong>Phone:</strong> @Model.OwnerPhone</p>
            <p><strong>Trust Score:</strong> @Model.OwnerTrustScore / 100</p>
        </div>
    </div>

    <div class="card mb-4">
        <div class="card-body">
            <h5>Reviews (@Model.ReviewCount)</h5>

            @if (Model.Reviews.Any())
            {
                <p><strong>Average Rating:</strong> @Model.AverageRating.ToString("F1") / 5</p>

                @foreach (var review in Model.Reviews)
                {
                    <div class="border p-3 mb-3 rounded">

                        <strong>@review.ReviewerName</strong>
                        <span class="text-muted">(@review.CreatedAt.ToString("dd MMM yyyy"))</span>

                        <div>
                            Rating: @review.Rating / 5
                        </div>

                        <p>@review.Comment</p>

                    </div>
                }
            }
            else
            {
                <p>No reviews yet.</p>
            }
        </div>
    </div>

</div>





<style>
    .container {
        max-width: 1100px;
        margin: auto;
        padding: 20px;
        font-family: 'Segoe UI', sans-serif;
    }

    h2 {
        font-size: 26px;
        font-weight: 600;
        margin-bottom: 5px;
    }

    h4 {
        color: #4f46e5;
        margin-bottom: 10px;
    }

    h5 {
        margin-bottom: 12px;
        font-weight: 600;
    }

    .main-image {
        width: 100%;
        max-height: 400px;
        object-fit: cover;
        border-radius: 10px;
        transition: transform 0.3s ease;
        cursor: pointer;
    }

        .main-image:hover {
            transform: scale(1.02);
        }

    .thumbnail-container {
        display: flex;
        gap: 10px;
        margin-top: 10px;
        flex-wrap: wrap;
    }

    .thumbnail {
        width: 80px;
        height: 60px;
        object-fit: cover;
        border-radius: 6px;
        cursor: pointer;
        opacity: 0.7;
        border: 2px solid transparent;
        transition: 0.2s;
    }

        .thumbnail:hover,
        .thumbnail.active {
            opacity: 1;
            border-color: #4f46e5;
        }

    .card {
        border: 1px solid #e5e7eb;
        border-radius: 10px;
        padding: 15px;
        background: #fff;
        margin-bottom: 20px;
    }

    .card-body {
        padding: 10px;
    }

    .row {
        display: flex;
        flex-wrap: wrap;
        gap: 10px;
    }

    .col-md-4 {
        flex: 1 1 calc(33.33% - 10px);
        font-size: 14px;
    }

    .review-box {
        border: 1px solid #e5e7eb;
        padding: 12px;
        border-radius: 8px;
        margin-bottom: 10px;
        background: #fafafa;
    }

        .review-box strong {
            display: block;
            margin-bottom: 5px;
        }

    .text-muted {
        color: #6b7280;
        font-size: 12px;
    }

    .btn {
        padding: 10px 14px;
        border-radius: 8px;
        border: none;
        cursor: pointer;
        font-weight: 500;
    }

    .btn-primary {
        background: #4f46e5;
        color: white;
    }

        .btn-primary:hover {
            background: #4338ca;
        }
</style>

<script>
    document.addEventListener("DOMContentLoaded", function () {

        const mainImage = document.getElementById("mainImg");
        const thumbnails = document.querySelectorAll(".thumbnail");

        if (!mainImage || thumbnails.length === 0) return;

        thumbnails.forEach((thumb) => {
            thumb.addEventListener("click", function () {

                mainImage.src = this.src;

                thumbnails.forEach(t => t.classList.remove("active"));
                this.classList.add("active");
            });
        });

        mainImage.addEventListener("click", function () {
            this.style.transform =
                this.style.transform === "scale(1.5)"
                ? "scale(1)"
                : "scale(1.5)";
        });

    });
</script>