@model RentalsAndProperties.Web.ViewModels.Property.PropertyDetailViewModel

@{
    ViewData["Title"] = Model.Title;
    var currentUser = User.Identity?.Name;
    bool isOwner = !string.IsNullOrEmpty(currentUser) &&
                   currentUser.Equals(Model.OwnerName, StringComparison.OrdinalIgnoreCase);
}

@if (Model == null)
{
    <div class="text-center mt-5">
        <h2>Property not found</h2>
        <a asp-controller="Property" asp-action="Browse" class="btn btn-primary">
            Browse Properties
        </a>
    </div>
    return;
}

<div class="container mt-4">

    <div class="mb-3">
        <h2>@Model.Title</h2>
        <h4>
            ₹@Model.Price.ToString("N0")
            @if (Model.ListingType == "Rent")
            {
                <span>/month</span>
            }
        </h4>
        <p>@Model.City, @Model.Address</p>
    </div>

    <div class="mb-4">

        @if (Model.AllImageUrls.Any())
        {
            <img id="mainImg"
                 src="@Model.PrimaryImageUrl"
                 class="main-image img-fluid rounded"
                 style="width:100%; object-fit:contain;" />

            <div class="mt-2 d-flex flex-wrap gap-2">
                @foreach (var img in Model.AllImageUrls)
                {
                    <img src="@img"
                         class="thumbnail"
                         style="width:80px;height:60px;object-fit:cover;cursor:pointer;" />
                }
            </div>
        }
        else
        {
            <div class="no-image-box">
                <span class="house-icon">🏠</span>
                <p>No images available</p>
            </div>
        }

    </div>

    <div class="card mb-4">
        <div class="card-body">
            <h5>

            </h5>
            <p>@Model.Description</p>
        </div>
    </div>

    <div class="card mb-4">
        <div class="card-body">
            <h5>Property Details</h5>

            <div class="row">

                <div class="col-md-4"><strong>Bedrooms:</strong> @Model.Bedrooms</div>
                <div class="col-md-4"><strong>Bathrooms:</strong> @Model.Bathrooms</div>
                <div class="col-md-4"><strong>Area:</strong> @Model.SquareFeet sq.ft</div>

                <div class="col-md-4"><strong>Type:</strong> @Model.PropertyType</div>
                <div class="col-md-4"><strong>BHK:</strong> @Model.BHKType</div>
                <div class="col-md-4"><strong>Furnishing:</strong> @Model.FurnishingType</div>

                <div class="col-md-4">
                    <strong>Available From:</strong>
                    @Model.AvailableFrom.ToString("dd MMM yyyy")
                </div>

                @if (Model.SecurityDeposit.HasValue)
                {
                    <div class="col-md-4">
                        <strong>Deposit:</strong> ₹@Model.SecurityDeposit.Value.ToString("N0")
                    </div>
                }

                <div class="col-md-4"><strong>Status:</strong> @Model.Status</div>

            </div>
        </div>
    </div>

    @if (!isOwner)
    {
        <div class="card mb-4">
            <div class="card-body">
                <h5>Owner Details</h5>

                <p><strong>Name:</strong> @Model.OwnerName</p>
                <p><strong>Phone:</strong> @Model.OwnerPhone</p>
            </div>
        </div>

        <div class="card mb-4">
            <div class="action-buttons">

                <a asp-controller="Review"
                   asp-action="Create"
                   asp-route-propertyId="@Model.PropertyId"
                   class="btn btn-review">
                    ✍️ Write Review
                </a>

                <a asp-controller="Report"
                   asp-action="Create"
                   asp-route-targetId="@Model.PropertyId"
                   asp-route-targetType="Property"
                   asp-route-targetTitle="@Model.Title"
                   class="btn btn-report">
                    🚩 Report Property
                </a>


                <a asp-controller="Transaction"
                   asp-action="Initiate"
                   asp-route-propertyId="@Model.PropertyId"
                   class="btn btn-primary">
                    💰 Start Transaction
                </a>

            </div>
        </div>
    }
    <div class="card mb-4">
        <div class="card-body">

            <h5 class="mb-3">Reviews (@Model.Reviews.Count)</h5>

            @if (Model.Reviews.Any())
            {
                <p class="mb-4">
                    <strong>Average Rating:</strong>
                    @Model.Reviews.Average(r => r.Rating).ToString("F1") / 5
                </p>

                @foreach (var review in Model.Reviews)
                {
                    <div class="review-item">

                        <div class="review-header">

                            <div>
                                <strong>@review.ReviewerName</strong>
                                <span class="text-muted">
                                    • @review.CreatedAt.ToString("dd MMM yyyy")
                                </span>
                            </div>

                            <span class="badge @(review.ReviewType == "Transaction" ? "badge-success" : "badge-secondary")">
                                @review.ReviewType
                            </span>

                        </div>

                        <div class="review-rating">
                            @for (int i = 1; i <= 5; i++)
                            {
                                <span class="star @(i <= review.Rating ? "filled" : "")">★</span>
                            }
                        </div>

                        <p class="review-comment">@review.Comment</p>

                    </div>
                }
            }
            else
            {
                <p class="text-muted">No reviews yet.</p>
            }

        </div>
    </div>

    

</div>





<style>
    .container {
        max-width: 1100px;
        margin: auto;
        padding: 20px;
        font-family: 'Segoe UI', sans-serif;
    }

    h2 {
        font-size: 26px;
        font-weight: 600;
        margin-bottom: 5px;
    }

    h4 {
        color: #4f46e5;
        margin-bottom: 10px;
    }

    h5 {
        margin-bottom: 12px;
        font-weight: 1000;
    }

    .main-image {
        width: 100%;
        max-height: 400px;
        object-fit: cover;
        border-radius: 10px;
        transition: transform 0.3s ease;
        cursor: pointer;
    }

        .main-image:hover {
            transform: scale(1.02);
        }

    .no-image-box {
        width: 100%;
        height: 300px;
        border: 2px solid #d1d5db;
        border-radius: 10px;
        display: flex;
        flex-direction: column;
        align-items: center;
        justify-content: center;
        color: #6b7280;
        margin: 20px auto;
    }

    .house-icon {
        font-size: 60px;
        margin-bottom: 10px;
    }
    .thumbnail-container {
        display: flex;
        gap: 10px;
        margin-top: 10px;
        flex-wrap: wrap;
    }

    .thumbnail {
        width: 80px;
        height: 60px;
        object-fit: cover;
        border-radius: 6px;
        cursor: pointer;
        opacity: 0.7;
        border: 2px solid transparent;
        transition: 0.2s;
    }

        .thumbnail:hover,
        .thumbnail.active {
            opacity: 1;
            border-color: #4f46e5;
        }

    .card {
        color:black;
        border: 1px solid #e5e7eb;
        border-radius: 10px;
        padding: 15px;
        background: #fff;
        margin-bottom: 20px;
    }

    .card-body {
        padding: 10px;
    }

    .row {
        display: flex;
        flex-wrap: wrap;
        gap: 10px;
    }

    .col-md-4 {
        flex: 1 1 calc(33.33% - 10px);
        font-size: 14px;
    }

    .review-box {
        border: 1px solid #e5e7eb;
        padding: 12px;
        border-radius: 8px;
        margin-bottom: 10px;
        background: #fafafa;
    }

        .review-box strong {
            display: block;
            margin-bottom: 5px;
        }

    .text-muted {
        color: #6b7280;
        font-size: 12px;
    }

    .btn {
        padding: 10px 14px;
        border-radius: 8px;
        border: none;
        cursor: pointer;
        font-weight: 500;
    }

    .btn-primary {
        background: #4f46e5;
        color: white;
    }

        .btn-primary:hover {
            background: #4338ca;
        }
    .action-buttons {
        display: flex;
        gap: 12px;
        margin: 20px 0;
        flex-wrap: wrap;
    }

    .btn {
        padding: 12px 18px;
        border-radius: 8px;
        font-weight: 600;
        text-decoration: none;
        display: inline-flex;
        align-items: center;
        justify-content: center;
        gap: 6px;
        transition: all 0.2s ease;
        border: none;
        cursor: pointer;
    }

    .btn-review {
        background: #4f46e5;
        color: white;
    }

        .btn-review:hover {
            background: #4338ca;
            transform: translateY(-1px);
        }

    .btn-report {
        background: #fee2e2;
        color: #b91c1c;
    }

        .btn-report:hover {
            background: #fecaca;
            transform: translateY(-1px);
        }

    .btn:active {
        transform: scale(0.98);
    }

    .review-item {
        border-top: 1px solid #e5e7eb;
        padding: 15px 0;
    }


    .review-header {
        display: flex;
        justify-content: space-between;
        align-items: center;
        margin-bottom: 6px;
    }

    .review-rating {
        margin-bottom: 6px;
    }

    .star {
        font-size: 16px;
        color: #d1d5db;
    }

        .star.filled {
            color: #f59e0b;
        }

    .review-comment {
        font-size: 14px;
        color: #374151;
        margin: 0;
    }

    .badge-success {               @*transaction*@
        background: #dcfce7;
        color: #166534;
        padding: 4px 10px;
        border-radius: 999px;
        font-size: 12px;
    }

    .badge-secondary {            @*Interaction*@
        background: #e5e7eb;
        color: #374151;
        padding: 4px 10px;
        border-radius: 999px;
        font-size: 12px;
    }
</style>

<script>
    document.addEventListener("DOMContentLoaded", function () {

        const mainImage = document.getElementById("mainImg");
        const thumbnails = document.querySelectorAll(".thumbnail");

        if (!mainImage || thumbnails.length === 0) return;

        thumbnails.forEach((thumb) => {
            thumb.addEventListener("click", function () {

                mainImage.src = this.src; //Replace main image with clicked thumbnail

                thumbnails.forEach(t => t.classList.remove("active"));
                this.classList.add("active");
            });
        });

        mainImage.addEventListener("click", function () {
            this.style.transform =
                this.style.transform === "scale(1.5)"
                ? "scale(1)"
                : "scale(1.5)";
        });

    });
</script>