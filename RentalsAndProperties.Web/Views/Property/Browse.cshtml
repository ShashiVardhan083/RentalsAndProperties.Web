@model RentalsAndProperties.Web.ViewModels.Property.PropertySearchResultViewModel

@{
    ViewData["Title"] = "Browse Properties";
}

<div class="browse-container">

    
        @using (Html.BeginForm("Browse", "Property", FormMethod.Get, new { id = "filterForm" }))
        {
            <div class="filters">

                @Html.DropDownList("City",
                Model.Cities,
                "All Cities",
                new { @class = "input" })

        <div class="radio-group">

            <label>
                @Html.RadioButton("ListingType", "", string.IsNullOrEmpty(Model.Query.ListingType))
                All
            </label>

            @foreach (var item in Model.ListingTypes)
                {
                    <label>
                        @Html.RadioButton("ListingType", item.Value, Model.Query.ListingType == item.Value)
                        @item.Text
                    </label>
                }

        </div>

        @Html.TextBox("MinPrice", Model.Query.MinPrice, new
        {
            @class = "input",
            type = "number",
            placeholder = "Min Price"
        })

        @Html.TextBox("MaxPrice", Model.Query.MaxPrice, new
                {
                    @class = "input",
                    type = "number",
                    placeholder = "Max Price"
                })

        @Html.DropDownList("BHKType",
                Model.BhkTypes,
                "All BHK",
                new { @class = "input" })

        @Html.DropDownList("FurnishingType",
                Model.FurnishingTypes,
                "All Furnishing",
                new { @class = "input" })

        @Html.DropDownList("SortBy",
                new SelectList(new[]
                {
                new { Value = "", Text = "Default" },
                new { Value = "PriceLowToHigh", Text = "Price Low to High" },
                new { Value = "PriceHighToLow", Text = "Price High to Low" }
                }, "Value", "Text", Model.Query.SortBy),
                new { @class = "input" })

        <button type="submit" class="btn btn-primary">Apply</button>

        <a href="/Property/Browse" class="btn btn-clear">Clear</a>

    </div>
        
    }

    <h2>@Model.TotalCount Properties Found</h2>

    @if (!Model.Properties.Any())
    {
        <p>No properties found</p>
    }
    else
    {
        <div class="grid">

            @foreach (var p in Model.Properties)
            {
                <div class="card">

                    <div class="card-img"
                         style="@(string.IsNullOrEmpty(p.PrimaryImageUrl)
                                  ? ""
                                  : $"background:url('{p.PrimaryImageUrl}') center/cover")">

                @if (string.IsNullOrEmpty(p.PrimaryImageUrl))
                        {
                            <span class="house-icon">🏠</span>
                        }

                        <span class="badge @(p.ListingType == "Rent" ? "rent" : "sale")">
                            @p.ListingType
                        </span>
                    </div>

                    <div class="card-body">

                        <div class="price">
                            ₹@p.Price.ToString("N0")
                    @if (p.ListingType == "Rent")
                            {
                                <span class="per">/mo</span>
                            }
                        </div>

                        <h4>@p.Title</h4>
                        <p>📍 @p.City</p>

                        <div class="chips">
                            <span>@p.PropertyType</span>
                            <span>@p.BHKType</span>
                        </div>

                        @if (Model.IsAuthenticated)
                        {
                            <a asp-action="Details"
                               asp-route-id="@p.PropertyId"
                               class="btn btn-primary">
                                View Details
                            </a>
                        }
                        else
                        {
                            <a asp-controller="Auth"
                               asp-action="Login"
                               asp-route-returnUrl="@($"/Property/Details/{p.PropertyId}")"
                               class="btn btn-secondary">
                                Login to View
                            </a>
                        }

                    </div>

                </div>
            }

        </div>
    }
    @if (Model.TotalPages > 1)
    {
        <div class="pagination">

            @if (Model.CurrentPage > 1)
            {
                <a href="?page=@(Model.CurrentPage - 1)">Prev</a>
            }

            <span>@Model.CurrentPage / @Model.TotalPages</span>

            @if (Model.CurrentPage < Model.TotalPages)
            {
                <a href="?page=@(Model.CurrentPage + 1)">Next</a>
            }

        </div>
    }

</div>


<style>
    body {
        background: #0f172a;
        color: #e2e8f0;
        font-family: "Segoe UI", sans-serif;
    }

    .browse-container {
        padding: 2rem;
    }

    .filters {
        display: flex;
        flex-wrap: wrap;
        gap: 10px;
        margin-bottom: 1.5rem;
    }

    .input {
        padding: 0.6rem;
        border-radius: 8px;
        border: none;
        background: #1e293b;
        color: white;
        min-width: 140px;
    }

    .radio-group {
        display: flex;
        gap: 15px;
        align-items: center;
    }

        .radio-group label {
            display: flex;
            align-items: center;
            gap: 6px;
            cursor: pointer;
            font-size: 0.9rem;
        }

        .radio-group input {
            accent-color: #6366f1;
        }

    .btn {
        padding: 0.5rem 1rem;
        border-radius: 8px;
        border: none;
        cursor: pointer;
        font-weight: 600;
        text-decoration: none;
        display: inline-block;
    }

    .btn-primary {
        background: #6366f1;
        color: white;
    }

        .btn-primary:hover {
            background: #4f46e5;
        }

    .btn-secondary {
        background: #334155;
        color: white;
    }

        .btn-secondary:hover {
            background: #1e293b;
        }

    .btn-clear {
        color: #ef4444;
        align-self: center;
    }

    .grid {
        display: grid;
        grid-template-columns: repeat(auto-fit, minmax(260px, 1fr));
        gap: 1.5rem;
    }

    .card {
        background: #1e293b;
        border-radius: 12px;
        overflow: hidden;
        transition: 0.3s ease;
    }

        .card:hover {
            transform: translateY(-5px);
        }

    .card-img {
        height: 170px;
        position: relative;
        background: #334155;
    }

    .card-img {
        height: 170px;
        position: relative;
        background: #334155;
        display: flex;
        align-items: center;
        justify-content: center;
    }

    .house-icon {
        font-size: 40px;
    }
    .badge {
        position: absolute;
        top: 10px;
        right: 10px;
        padding: 4px 10px;
        border-radius: 999px;
        font-size: 0.7rem;
        font-weight: 600;
    }

    .rent {
        background: rgba(34, 197, 94, 0.2);
        color: #22c55e;
    }

    .sale {
        background: rgba(245, 158, 11, 0.2);
        color: #f59e0b;
    }

    .card-body {
        padding: 1rem;
    }

    .price {
        font-weight: bold;
        color: #22c55e;
    }

    .per {
        font-size: 0.7rem;
    }

    .chips {
        margin-top: 5px;
        margin-bottom: 5px;
    }

        .chips span {
            background: #334155;
            padding: 4px 8px;
            border-radius: 999px;
            font-size: 0.7rem;
            margin-right: 5px;
        }

    

    .pagination {
        margin-top: 2rem;
        text-align: center;
    }

        .pagination a {
            margin: 0 10px;
            color: #818cf8;
            text-decoration: none;
            font-weight: 600;
        }

        .pagination span {
            font-weight: bold;
        }

</style>