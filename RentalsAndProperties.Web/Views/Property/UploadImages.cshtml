@model RentalsAndProperties.Web.Models.ViewModels.UploadImagesViewModel
@{
    ViewData["Title"] = "Manage Images – " + Model.PropertyTitle;
    var remaining = Model.MaxImages - Model.ExistingImages.Count;
}

<div class="upload-page">
    <!-- Page Header -->
    <div class="upload-page-header">
        <div class="upload-header-inner">
            <a href="/Property/Dashboard" class="back-link">← My Properties</a>
            <h1 class="upload-page-title">📸 Property Images</h1>
            <p class="upload-page-subtitle">
                <strong>@Model.PropertyTitle</strong>
                &nbsp;·&nbsp;
                <span class="img-counter" id="imgCounter">
                    @Model.ExistingImages.Count / @Model.MaxImages uploaded
                </span>
            </p>
        </div>
    </div>

    <div class="upload-page-body">

        @if (!string.IsNullOrEmpty(TempData["Success"]?.ToString()))
        {
            <div class="alert alert-success fade-in-up">✓ @TempData["Success"]</div>
        }
        @if (!string.IsNullOrEmpty(TempData["Error"]?.ToString()))
        {
            <div class="alert alert-error fade-in-up">⚠ @TempData["Error"]</div>
        }

        <!-- Current Images Grid -->
        @if (Model.ExistingImages.Any())
        {
            <div class="gallery-section">
                <div class="gallery-section-header">
                    <h2 class="gallery-section-title">Current Images</h2>
                    <span class="gallery-hint">Click ⭐ to set as cover · Click 🗑 to remove</span>
                </div>
                <div class="managed-gallery" id="managedGallery">
                    @foreach (var img in Model.ExistingImages.OrderByDescending(i => i.IsPrimary))
                    {
                        <div class="managed-img-card @(img.IsPrimary ? "is-primary" : "")"
                             data-image-id="@img.ImageId">
                            <div class="managed-img-wrap">
                                <img src="@img.ImageUrl"
                                     alt="Property image"
                                     loading="lazy"
                                     class="managed-img" />
                                @if (img.IsPrimary)
                                {
                                    <div class="primary-crown" title="Cover photo">⭐ Cover</div>
                                }
                                <div class="managed-img-overlay">
                                    @if (!img.IsPrimary)
                                    {
                                        <form asp-action="SetPrimaryImage" asp-controller="Property"
                                              method="post" style="display:inline;">
                                            @Html.AntiForgeryToken()
                                            <input type="hidden" name="imageId" value="@img.ImageId" />
                                            <input type="hidden" name="propertyId" value="@Model.PropertyId" />
                                            <button type="submit" class="img-action-btn img-btn-primary"
                                                    title="Set as cover photo">
                                                ⭐
                                            </button>
                                        </form>
                                    }
                                    <form asp-action="DeleteImage" asp-controller="Property"
                                          method="post" style="display:inline;"
                                          onsubmit="return confirm('Delete this image?')">
                                        @Html.AntiForgeryToken()
                                        <input type="hidden" name="imageId" value="@img.ImageId" />
                                        <input type="hidden" name="propertyId" value="@Model.PropertyId" />
                                        <button type="submit" class="img-action-btn img-btn-delete"
                                                title="Delete image">
                                            🗑
                                        </button>
                                    </form>
                                </div>
                            </div>
                        </div>
                    }
                </div>
            </div>
        }

        <!-- Upload Zone (only show if slots remain) -->
        @if (remaining > 0)
        {
            <div class="upload-section">
                <div class="gallery-section-header">
                    <h2 class="gallery-section-title">Add New Images</h2>
                    <span class="gallery-hint">Up to @remaining more · JPG, PNG, WebP · Max 5MB each</span>
                </div>

                <form asp-action="UploadImages" asp-controller="Property"
                      asp-route-id="@Model.PropertyId"
                      method="post" enctype="multipart/form-data"
                      id="uploadForm" novalidate>
                    @Html.AntiForgeryToken()

                    <!-- Drop Zone -->
                    <div class="drop-zone" id="dropZone" tabindex="0"
                         role="button" aria-label="Click or drag images here">
                        <input type="file" name="Images" id="fileInput"
                               accept=".jpg,.jpeg,.png,.webp" multiple
                               class="file-input-hidden" />
                        <div class="drop-zone-icon">📁</div>
                        <p class="drop-zone-title">
                            <strong>Click to browse</strong> or drag &amp; drop images here
                        </p>
                        <p class="drop-zone-sub">JPG · PNG · WebP &nbsp;·&nbsp; Max 5 MB each &nbsp;·&nbsp; Up to @remaining images</p>
                    </div>

                    <!-- Preview Grid -->
                    <div class="new-preview-grid" id="newPreviewGrid"></div>

                    <!-- Upload Bar -->
                    <div class="upload-actions" id="uploadActions" style="display:none;">
                        <div class="upload-progress-wrap" id="uploadProgressWrap" style="display:none;">
                            <div class="upload-progress-bar" id="uploadProgressBar"></div>
                            <span class="upload-progress-label" id="uploadProgressLabel">Uploading…</span>
                        </div>
                        <div class="flex gap-3 items-center">
                            <span class="selected-count" id="selectedCount"></span>
                            <button type="button" class="btn btn-secondary btn-sm" id="clearBtn">
                                Clear All
                            </button>
                            <button type="submit" class="btn btn-primary" id="uploadBtn">
                                <span class="btn-text">⬆ Upload Images</span>
                                <span class="btn-spinner"></span>
                            </button>
                        </div>
                    </div>
                </form>
            </div>
        }
        else
        {
            <div class="alert alert-info">
                <span>ℹ</span>
                <span>
                    You've reached the maximum of @Model.MaxImages images.
                    Delete existing images to add new ones.
                </span>
            </div>
        }

        <div class="form-submit-bar">
            <a href="/Property/Dashboard" class="btn btn-secondary">← Back to My Properties</a>
            <a href="/Property/Details/@Model.PropertyId" class="btn btn-primary">
                View Property →
            </a>
        </div>
    </div>
</div>

@section HeadStyles {
    <style>
        /* ── Upload Page Layout ── */
        .upload-page {
            padding-top: 68px;
            min-height: 100vh;
        }

        .upload-page-header {
            background: var(--gradient-hero);
            border-bottom: 1px solid var(--border-subtle);
            padding: 2rem;
        }

        .upload-header-inner {
            max-width: 960px;
            margin: 0 auto;
        }

        .upload-page-title {
            font-size: 1.6rem;
            font-weight: 800;
        }

        .upload-page-subtitle {
            color: var(--text-secondary);
            margin-top: .3rem;
        }

        .upload-page-body {
            max-width: 960px;
            margin: 0 auto;
            padding: 2rem;
        }

        .img-counter {
            display: inline-flex;
            align-items: center;
            gap: .4rem;
            padding: .25rem .75rem;
            background: rgba(108,99,255,.1);
            border: 1px solid rgba(108,99,255,.2);
            border-radius: 100px;
            font-size: .8rem;
            font-weight: 600;
            color: var(--accent-1);
        }

        /* ── Gallery Section ── */
        .gallery-section, .upload-section {
            margin-bottom: 2.5rem;
        }

        .gallery-section-header {
            display: flex;
            align-items: baseline;
            justify-content: space-between;
            margin-bottom: 1rem;
            gap: 1rem;
            flex-wrap: wrap;
        }

        .gallery-section-title {
            font-size: 1.1rem;
            font-weight: 700;
        }

        .gallery-hint {
            font-size: .8rem;
            color: var(--text-muted);
        }

        /* ── Managed Gallery Grid ── */
        .managed-gallery {
            display: grid;
            grid-template-columns: repeat(auto-fill, minmax(180px, 1fr));
            gap: 1rem;
        }

        .managed-img-card {
            border-radius: var(--radius-md);
            overflow: hidden;
            border: 2px solid var(--border-subtle);
            position: relative;
            transition: border-color .2s, transform .2s var(--spring), box-shadow .2s;
            background: var(--bg-card);
            aspect-ratio: 4/3;
        }

            .managed-img-card:hover {
                border-color: var(--border-accent);
                transform: translateY(-3px);
                box-shadow: var(--shadow-card);
            }

            .managed-img-card.is-primary {
                border-color: var(--accent-3);
                border-width: 3px;
            }

        .managed-img-wrap {
            position: relative;
            width: 100%;
            height: 100%;
        }

        .managed-img {
            width: 100%;
            height: 100%;
            object-fit: cover;
            display: block;
        }

        .primary-crown {
            position: absolute;
            top: .5rem;
            left: .5rem;
            background: rgba(67,233,123,.9);
            color: #000;
            font-size: .65rem;
            font-weight: 800;
            padding: .2rem .6rem;
            border-radius: 100px;
            letter-spacing: .04em;
            text-transform: uppercase;
        }

        .managed-img-overlay {
            position: absolute;
            inset: 0;
            background: rgba(0,0,0,.5);
            display: flex;
            align-items: center;
            justify-content: center;
            gap: .5rem;
            opacity: 0;
            transition: opacity .2s;
        }

        .managed-img-card:hover .managed-img-overlay {
            opacity: 1;
        }

        .img-action-btn {
            width: 40px;
            height: 40px;
            border-radius: 50%;
            border: none;
            cursor: pointer;
            font-size: 1rem;
            display: flex;
            align-items: center;
            justify-content: center;
            transition: transform .15s var(--spring), box-shadow .15s;
        }

            .img-action-btn:hover {
                transform: scale(1.12);
                box-shadow: 0 4px 12px rgba(0,0,0,.3);
            }

        .img-btn-primary {
            background: rgba(67,233,123,.9);
            color: #000;
        }

        .img-btn-delete {
            background: rgba(239,68,68,.9);
            color: #fff;
        }

        /* ── Drop Zone ── */
        .drop-zone {
            border: 2px dashed var(--border-accent);
            border-radius: var(--radius-lg);
            padding: 3.5rem 2rem;
            text-align: center;
            cursor: pointer;
            transition: border-color .2s, background .2s, transform .15s var(--spring);
            background: rgba(108,99,255,.03);
        }

            .drop-zone:hover, .drop-zone.drag-active {
                border-color: var(--accent-1);
                background: rgba(108,99,255,.07);
                transform: scale(1.01);
            }

            .drop-zone.drag-active {
                border-style: solid;
            }

        .drop-zone-icon {
            font-size: 3rem;
            margin-bottom: .75rem;
        }

        .drop-zone-title {
            font-size: 1rem;
            font-weight: 600;
            color: var(--text-primary);
            margin-bottom: .25rem;
        }

        .drop-zone-sub {
            font-size: .82rem;
            color: var(--text-muted);
        }

        /* ── New Preview Grid ── */
        .new-preview-grid {
            display: grid;
            grid-template-columns: repeat(auto-fill, minmax(130px, 1fr));
            gap: .75rem;
            margin-top: 1rem;
        }

        .new-preview-item {
            position: relative;
            border-radius: var(--radius-sm);
            overflow: hidden;
            border: 2px solid var(--border-subtle);
            aspect-ratio: 4/3;
            background: var(--bg-card);
            animation: popIn .2s var(--spring);
        }

            .new-preview-item img {
                width: 100%;
                height: 100%;
                object-fit: cover;
                display: block;
            }

        .new-preview-remove {
            position: absolute;
            top: 4px;
            right: 4px;
            width: 22px;
            height: 22px;
            background: rgba(239,68,68,.9);
            border: none;
            border-radius: 50%;
            color: #fff;
            font-size: .7rem;
            cursor: pointer;
            display: flex;
            align-items: center;
            justify-content: center;
        }

        .new-preview-badge {
            position: absolute;
            bottom: 4px;
            left: 4px;
            background: rgba(67,233,123,.9);
            color: #000;
            font-size: .6rem;
            font-weight: 800;
            padding: 1px 5px;
            border-radius: 3px;
        }

        /* ── Upload Actions ── */
        .upload-actions {
            margin-top: 1.25rem;
            display: flex;
            align-items: center;
            justify-content: space-between;
            flex-wrap: wrap;
            gap: 1rem;
        }

        .selected-count {
            font-size: .875rem;
            color: var(--text-secondary);
            font-weight: 500;
        }

        .upload-progress-wrap {
            position: relative;
            height: 6px;
            background: var(--border-subtle);
            border-radius: 100px;
            overflow: hidden;
            margin-bottom: .5rem;
        }

        .upload-progress-bar {
            position: absolute;
            left: 0;
            top: 0;
            bottom: 0;
            background: var(--gradient-btn);
            border-radius: 100px;
            width: 0%;
            transition: width .3s ease;
        }

        .upload-progress-label {
            font-size: .78rem;
            color: var(--text-muted);
            display: block;
            text-align: center;
            margin-top: .3rem;
        }

        @@media(max-width:600px) {
            .managed-gallery {
                grid-template-columns: repeat(auto-fill,minmax(130px,1fr));
            }

            .new-preview-grid {
                grid-template-columns: repeat(auto-fill,minmax(100px,1fr));
            }
        }
    </style>
}

@section Scripts {
    <script src="~/js/imageUpload.js" asp-append-version="true"></script>
    <script>
        document.addEventListener('DOMContentLoaded', function () {
            initImageUpload({
                dropZoneId: 'dropZone',
                fileInputId: 'fileInput',
                previewGridId: 'newPreviewGrid',
                uploadActionsId: 'uploadActions',
                uploadBtnId: 'uploadBtn',
                clearBtnId: 'clearBtn',
                selectedCountId: 'selectedCount',
                maxFiles: @remaining,
                maxSizeMB: 5
            });
        });
    </script>
}
