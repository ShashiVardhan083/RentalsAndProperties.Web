@model RentalsAndProperties.Web.ViewModels.Property.EditPropertyViewModel

@{
    ViewData["Title"] = "Edit Property";
}

<div class="form-page">
    @Html.ValidationSummary(true, "", new { @class = "alert alert-danger" })
    <form asp-action="Edit" asp-controller="Property"
          method="post" enctype="multipart/form-data">

        @Html.AntiForgeryToken()

        @Html.HiddenFor(m => m.PropertyId)

        @await Html.PartialAsync("_PropertyFormFields", Model)

        <h3>Existing Images</h3>

        <div class="image-preview-container">
            @foreach (var img in Model.ExistingImages)
            {
                <div class="preview-item">
                    <img src="@img.ImageUrl" />
                    <input type="checkbox" name="RemoveImageIds" value="@img.ImageId" /> Remove
                </div>
            }
        </div>

        @* New images — Edit only *@
        <h3>Add New Images</h3>

        <div class="form-group">
            @Html.LabelFor(m => m.Images)
            <input type="file" name="Images" multiple class="form-control" />
            @Html.ValidationMessageFor(m => m.Images, "", new { @class = "text-danger" })
        </div>

        <br />
        <button type="submit" class="btn btn-primary">
			Update Property<a href="c:\users\shashi podeti\source\repos\rentalsandproperties.web\rentalsandproperties.web\views\property\edit.cshtml">c:\users\shashi podeti\source\repos\rentalsandproperties.web\rentalsandproperties.web\views\property\edit.cshtml</a>
        </button>

    </form>
</div>
