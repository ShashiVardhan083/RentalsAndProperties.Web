@model List<RentalsAndProperties.Web.ViewModels.Property.PropertyCardViewModel>

@{
    ViewData["Title"] = "My Properties";
}

<div class="container mt-4">

    <!-- HEADER -->
    <div class="page-header">
        <div>
            <h2 class="page-title">My Properties</h2>
            <p class="page-subtitle">Manage your listings</p>
        </div>

        <a asp-controller="Property"
           asp-action="Create"
           class="btn-add">
            + Add Property
        </a>
    </div>

    <!-- ALERTS -->
    @if (!string.IsNullOrEmpty(ViewBag.Success?.ToString()))
    {
        <div class="alert alert-success">@ViewBag.Success</div>
    }
    else if (!string.IsNullOrEmpty(ViewBag.Error?.ToString()))
    {
        <div class="alert alert-danger">@ViewBag.Error</div>
    }

    <!-- EMPTY -->
    @if (Model == null || !Model.Any())
    {
        <div class="alert alert-info">
            No properties found. Start by adding one.
        </div>
    }
    else
    {
        <!-- TABLE -->
        <table class="table custom-table">
            <thead>
                <tr>
                    <th>Property</th>
                    <th>Price</th>
                    <th>Status</th>
                    <th>Actions</th>
                </tr>
            </thead>

            <tbody>
                @foreach (var p in Model)
                {
                    <tr class="property-row">

                        <!-- PROPERTY -->
                        <td>
                            <div class="prop-info">

                                <div class="table-img"
                                     style="@(string.IsNullOrEmpty(p.PrimaryImageUrl)
                                                                              ? ""
                                                                              : $"background-image:url('{p.PrimaryImageUrl}')")">

                                @if (string.IsNullOrEmpty(p.PrimaryImageUrl))
                                    {
                                        <span class="house-icon">🏠</span>
                                    }
                                </div>

                                <div>
                                    <div class="prop-title">@p.Title</div>
                                    <div class="prop-meta">@p.BHKType · @p.PropertyType</div>
                                    <div class="prop-city">📍 @p.City</div>
                                </div>
                            </div>
                        </td>

                        <!-- PRICE -->
                        <td class="price-cell">
                            ₹@p.Price.ToString("N0")
                            @if (p.ListingType == "Rent")
                            {
                                <span class="per">/mo</span>
                            }
                        </td>

                        <!-- STATUS -->
                        <td>
                            <span class="status-pill status-@p.Status.ToLower()">
                                @(p.Status == "PendingApproval" ? "Pending" : p.Status)
                            </span>
                        </td>

                        <!-- ACTIONS -->
                        <td>
                            <div class="action-buttons">

                                <a asp-action="Details"
                                   asp-route-id="@p.PropertyId"
                                   class="btn-view">
                                    View
                                </a>

                                <a asp-action="Edit"
                                   asp-route-id="@p.PropertyId"
                                   class="btn-edit">
                                    Edit
                                </a>

                                <form asp-action="Delete"
                                      asp-controller="Property"
                                      asp-route-id="@p.PropertyId"
                                      method="post">

                                    @Html.AntiForgeryToken()

                                    <button type="submit"
                                            class="btn-delete"
                                            onclick="return confirm('Delete this property?');">
                                        Delete
                                    </button>

                                </form>

                            </div>
                        </td>

                    </tr>
                }
            </tbody>
        </table>
    }
</div>


<style>
    .table {
        width: 100%;
        background: #1e293b;
        color: #e2e8f0;
        border-radius: 10px;
        overflow: hidden;
    }

        .table th {
            background: #0f172a;
            color: #94a3b8;
            font-size: 0.8rem;
            text-transform: uppercase;
        }

        .table td {
            vertical-align: middle;
        }

        .table tbody tr:hover {
            background: rgba(99, 102, 241, 0.1);
        }

    .page-header {
        display: flex;
        justify-content: space-between;
        align-items: center;
        margin-bottom: 20px;
    }

    .page-title {
        font-size: 1.6rem;
        font-weight: 700;
        margin: 0;
    }

    .page-subtitle {
        font-size: 0.85rem;
        color: #94a3b8;
        margin-top: 2px;
    }

    .btn-add {
        background: linear-gradient(135deg, #6366f1, #4f46e5);
        color: white;
        padding: 10px 16px;
        border-radius: 10px;
        font-weight: 600;
        text-decoration: none;
        font-size: 0.9rem;
        display: inline-flex; /*span*/
        align-items: center;
        gap: 6px;
        transition: 0.2s ease;
    }

        .btn-add:hover {
            transform: translateY(-2px);
            box-shadow: 0 6px 14px rgba(99,102,241,0.3);
        }

    /* PROPERTY ROW */
    .property-row td {
        padding: 16px 12px;
        vertical-align: middle;
    }

    /* PROPERTY INFO */
    .prop-info {
        display: flex;
        gap: 12px;
        align-items: center;
    }

    .prop-title {
        font-weight: 600;
        font-size: 0.95rem;
    }

    .prop-meta {
        font-size: 0.75rem;
        color: #94a3b8;
    }

    .prop-city {
        font-size: 0.75rem;
        color: #64748b;
    }

    .table-img {
        width: 70px;
        height: 55px;
        border-radius: 8px;
        background: #334155;
        background-size: cover; /* crop to fit*/
        background-position: center; /* show center of the image */
        display: flex;
        align-items: center;
        justify-content: center;
    }

    .house-icon {
        font-size: 22px;
        opacity: 0.7;
    }

    .price-cell {
        font-weight: bold;
        color: #22c55e;
    }

    .per {
        font-size: 0.75rem;
        color: #94a3b8;
    }

    .feature-cell {
        font-size: 0.8rem;
        color: #cbd5f5;
        line-height: 1.4;
    }

    .status-pill {
        padding: 5px 10px;
        border-radius: 999px;
        font-size: 0.7rem;
        font-weight: 600;
    }

    .status-active {
        background: rgba(34,197,94,0.2);
        color: #22c55e;
    }

    .status-rejected {
        background: rgba(239,68,68,0.2);
        color: #ef4444;
    }

    .status-pendingapproval {
        background: rgba(245,158,11,0.2);
        color: #f59e0b;
    }
    
    .status-sold {
        background: rgba(59,130,246,0.2); /* blue */
        color: #3b82f6;
    }

    .status-rented {
        background: rgba(168,85,247,0.2); /* purple */
        color: #a855f7;
    }

    .action-buttons {
        display: flex;
        gap: 8px;
        flex-wrap: wrap;
    }

    .btn-view,
    .btn-edit,
    .btn-delete {
        padding: 4px 10px;
        border-radius: 6px;
        font-size: 0.75rem;
        text-decoration: none;
        border: none;
        cursor: pointer;
    }

    .btn-view {
        background: rgba(99,102,241,0.2);
        color: #818cf8;
    }

    .btn-edit {
        background: rgba(245,158,11,0.2);
        color: #f59e0b;
    }

    .btn-delete {
        background: rgba(239,68,68,0.2);
        color: #ef4444;
    }

    .btn-view:hover {
        background: #6366f1;
        color: white;
    }

    .btn-edit:hover {
        background: #f59e0b;
        color: white;
    }

    .btn-delete:hover {
        background: #ef4444;
        color: white;
    }

    .alert-success {
        background: #065f46;
        color: #d1fae5;
        padding: 10px 14px;
        border-radius: 8px;
        margin-bottom: 1rem;
        font-size: 0.9rem;
    }

    .alert-danger {
        background: #7f1d1d;
        color: #fecaca;
        padding: 10px 14px;
        border-radius: 8px;
        margin-bottom: 1rem;
        font-size: 0.9rem;
    }
</style>