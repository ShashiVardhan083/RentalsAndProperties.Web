@model RentalsAndProperties.Web.Models.PagedResultModel<RentalsAndProperties.Web.Models.PropertyResponseModel>
@using RentalsAndProperties.Web.Helpers
@{
    ViewData["Title"] = "Browse Properties";
    var isAuth = SessionHelper.IsAuthenticated(Context.Session);
    var roles = SessionHelper.GetRoles(Context.Session);
    var isOwnerOrAdmin = roles.Contains("Owner") || roles.Contains("Admin");
    var isCustomerOnly = isAuth && !isOwnerOrAdmin;
}

<div class="prop-page">

    <!-- Page Header -->
    <div class="prop-hero">
        <div class="hero-orb orb-1" aria-hidden="true"></div>
        <div class="hero-orb orb-2" aria-hidden="true"></div>
        <div style="position:relative;z-index:1;text-align:center;padding:5rem 2rem 3rem;">
            <div class="hero-badge">🏠 Live Listings</div>
            <h1 class="hero-title" style="font-size:clamp(2rem,5vw,3.5rem);">
                Find Your <span class="gradient-text">Perfect Property</span>
            </h1>
            <p class="hero-subtitle">@(Model?.TotalCount ?? 0) verified properties available</p>
        </div>
    </div>

    <!-- Become Owner banner — visible to logged-in Customers only -->
    @if (isCustomerOnly)
    {
        <div class="become-owner-banner">
            <div class="become-owner-banner-inner">
                <div class="become-owner-banner-text">
                    <span class="become-owner-banner-icon">🏡</span>
                    <div>
                        <strong>Have a property to rent or sell?</strong>
                        <span style="color:var(--text-secondary);margin-left:.4rem;">
                            Become an Owner instantly and start listing for free.
                        </span>
                    </div>
                </div>
                <form asp-controller="Auth" asp-action="BecomeOwner" method="post" style="flex-shrink:0;">
                    @Html.AntiForgeryToken()
                    <button type="submit" class="btn btn-primary btn-sm"
                            onclick="return confirm('Become an Owner and start listing properties?')">
                        🏡 Become an Owner →
                    </button>
                </form>
            </div>
        </div>
    }

    <div class="section">
        @if (!string.IsNullOrEmpty(ViewBag.Error?.ToString()))
        {
            <div class="alert alert-error">⚠ @ViewBag.Error</div>
        }

        @if (Model == null || Model.Items.Count == 0)
        {
            <div class="empty-state">
                <div class="empty-icon">🏘️</div>
                <h3>No Properties Yet</h3>
                <p>Check back soon — new listings are added daily.</p>
                @if (isOwnerOrAdmin)
                {
                    <a href="/Property/Create" class="btn btn-primary mt-3">+ List Your Property</a>
                }
            </div>
        }
        else
        {
            <div class="properties-grid" role="list">
                @foreach (var p in Model.Items)
                {
                    <article class="property-card" role="listitem">
                        <!-- Image -->
                        <div class="property-img"
                             style="@(!string.IsNullOrEmpty(p.PrimaryImageUrl) ? $"background-image:url('{p.PrimaryImageUrl}');background-size:cover;background-position:center;" : "")">
                            @if (string.IsNullOrEmpty(p.PrimaryImageUrl))
                            {
                                <span aria-hidden="true" style="font-size:3rem;">🏠</span>
                            }
                            <div class="property-badge @(p.ListingType == "Rent" ? "badge-rent" : "badge-sale")">
                                @p.ListingType
                            </div>
                        </div>

                        <div class="property-body">
                            <div class="property-price">
                                ₹@p.Price.ToString("N0")
                                <span style="font-size:.65rem;font-weight:400;color:var(--text-muted);">
                                    @(p.ListingType == "Rent" ? "/mo" : "")
                                </span>
                            </div>
                            <h3 class="property-title">@p.Title</h3>
                            <div class="property-location">📍 @p.City</div>
                            <div class="prop-chips">
                                <span class="prop-chip">@p.PropertyType</span>
                                <span class="prop-chip">@p.BHKType</span>
                            </div>
                            <div class="property-footer">
                                @if (isAuth)
                                {
                                    <a href="/Property/Details/@p.PropertyId"
                                       class="btn-view-details">View Details →</a>
                                }
                                else
                                {
                                    <a href="/Auth/Login?returnUrl=/Property/Details/@p.PropertyId"
                                       class="btn-view-details">🔒 Login to View</a>
                                }
                                <span style="font-size:.75rem;color:var(--text-muted);">
                                    @p.CreatedAt.ToString("MMM dd")
                                </span>
                            </div>
                        </div>
                    </article>
                }
            </div>

            <!-- Pagination -->
            @if (Model.TotalPages > 1)
            {
                <div class="pagination">
                    @if (Model.HasPrevious)
                    {
                        <a href="/Property?page=@(Model.Page - 1)" class="btn btn-secondary btn-sm">← Prev</a>
                    }
                    <span class="page-info">Page @Model.Page of @Model.TotalPages</span>
                    @if (Model.HasNext)
                    {
                        <a href="/Property?page=@(Model.Page + 1)" class="btn btn-primary btn-sm">Next →</a>
                    }
                </div>
            }
        }
    </div>
</div>

@section HeadStyles {
    <style>
        .prop-hero {
            position: relative;
            min-height: 280px;
            background: var(--gradient-hero);
            overflow: hidden;
        }

        .prop-chips {
            display: flex;
            gap: .4rem;
            flex-wrap: wrap;
            margin: .6rem 0;
        }

        .prop-chip {
            padding: .2rem .6rem;
            background: rgba(99,102,241,.1);
            border: 1px solid rgba(99,102,241,.2);
            border-radius: 100px;
            font-size: .72rem;
            font-weight: 600;
            color: #a78bfa;
        }

        .badge-rent {
            background: rgba(67,233,123,.15);
            border-color: rgba(67,233,123,.3);
            color: #43e97b;
        }

        .badge-sale {
            background: rgba(247,151,30,.15);
            border-color: rgba(247,151,30,.3);
            color: #f59e0b;
        }

        .empty-state {
            text-align: center;
            padding: 5rem 2rem;
        }

        .empty-icon {
            font-size: 4rem;
            margin-bottom: 1rem;
        }

        .empty-state h3 {
            font-size: 1.5rem;
            margin-bottom: .5rem;
        }

        .empty-state p {
            color: var(--text-secondary);
        }

        .pagination {
            display: flex;
            justify-content: center;
            align-items: center;
            gap: 1rem;
            margin-top: 3rem;
        }

        .page-info {
            font-size: .875rem;
            color: var(--text-muted);
        }

        /* Become Owner Banner */
        .become-owner-banner {
            background: linear-gradient(90deg, rgba(99,102,241,.08) 0%, rgba(167,139,250,.08) 100%);
            border-top: 1px solid var(--border-accent);
            border-bottom: 1px solid var(--border-accent);
            padding: .85rem 2rem;
        }

        .become-owner-banner-inner {
            max-width: 1280px;
            margin: 0 auto;
            display: flex;
            align-items: center;
            justify-content: space-between;
            gap: 1rem;
            flex-wrap: wrap;
        }

        .become-owner-banner-text {
            display: flex;
            align-items: center;
            gap: .75rem;
            font-size: .9rem;
        }

        .become-owner-banner-icon {
            font-size: 1.5rem;
            flex-shrink: 0;
        }
    </style>
}
