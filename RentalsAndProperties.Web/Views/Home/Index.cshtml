@model RentalsAndProperties.Web.ViewModels.Property.PropertyListViewModel

@{
    ViewData["Title"] = "Find Your Perfect Home";

    var isAuthenticated = Model.IsAuthenticated;
    var fullName = Model.FullName;
    var roles = Model.Roles;

    var isOwnerOrAdmin = Model.IsOwnerOrAdmin;
    var isCustomerOnly = Model.IsCustomerOnly;

}

<p>@Model.TotalCount+ Listings Available</p>

<div class="hero-search">
    <input id="searchInput" type="text" placeholder="Search city..." />
    <button type="button" class="btn btn-primary" onclick="search()">Search</button>
</div>
<div class="section-header">
    <h2>Featured Properties</h2>
    <a asp-controller="Property" asp-action="Browse" class="view-all-link">
        View All →
    </a>
</div>

@if (!Model.Properties.Any())
{
    <p style="margin-top:2rem;">No properties available</p>
}
else
{
    <div class="grid">
        @foreach (var p in Model.Properties)
        {
            <div class="card">

                <div class="card-img"
                     style="@(string.IsNullOrEmpty(p.PrimaryImageUrl)
                                              ? ""
                                              : $"background:url('{p.PrimaryImageUrl}') center/cover")">

                    @if (string.IsNullOrEmpty(p.PrimaryImageUrl))
                    {
                        <span>🏠</span>
                    }
                </div>

                <div class="card-body">

                    <div class="price">
                        ₹@p.Price.ToString("N0") @*N = Number format, 0 = No decimal places*@
                        @if (p.ListingType == "Rent")
                        {
                            <span style="font-size:0.7rem;">/mo</span>
                        }
                    </div>

                    <h4>@p.Title</h4>
                    <p>📍 @p.City</p>

                    <span class="badge @(p.ListingType == "Rent" ? "rent" : "sale")">
                        @p.ListingType
                    </span>

                    <div style="margin-top:10px;">
                        @if (isAuthenticated)
                        {
                            <a asp-controller="Property"
                               asp-action="Details"
                               asp-route-id="@p.PropertyId"
                               class="btn btn-primary">
                                View Details
                            </a>
                        }
                        else
                        {
                            <a asp-controller="Auth"
                               asp-action="Login"
                               asp-route-returnUrl="@($"/Property/Details/{p.PropertyId}")"
                               class="btn btn-secondary">
                                Login to View
                            </a>
                        }
                    </div>

                </div>
            </div>
        }
    </div>
}
@if (!isAuthenticated)
{
    <h2>Join & Find Your Home</h2>
    <a asp-controller="Auth" asp-action="Register" class="btn btn-primary">Register</a>
    <a asp-controller="Auth" asp-action="Login" class="btn btn-secondary">Login</a>
}
else if (isCustomerOnly)
{
    <h2>Welcome, @fullName 👋</h2>

    <div class="roles">
        @foreach (var role in roles)
        {
            <span>@role</span>
        }
    </div>

    <form asp-controller="Auth" asp-action="BecomeOwner" method="post" style="margin-top:1rem;">
        @Html.AntiForgeryToken()
        <button type="submit" class="btn btn-primary">Become Owner</button>
    </form>
}
else
{
    <h2>Welcome back, @fullName 👋</h2>

    <div class="roles">
        @foreach (var role in roles)
        {
            <span>@role</span>
        }
    </div>

    <div style="margin-top:1rem;">
        <a asp-controller="Property" asp-action="Create" class="btn btn-primary">Add Property</a>
        <a asp-controller="Property" asp-action="Dashboard" class="btn btn-secondary">My Listings</a>

        @if (roles.Contains("Admin"))
        {
            <a asp-controller="Admin" asp-action="Index" class="btn btn-secondary">Admin Panel</a>
        }
    </div>
}

<style>
    body {
        background: #0f172a;
        color: #e2e8f0;
        font-family: "Segoe UI", sans-serif;
    }

    h2 {
        margin-top: 2rem;
        margin-bottom: 1rem;
        font-weight: 700;
    }

    p {
        color: #cbd5e1;
    }

    /* SEARCH */
    .hero-search {
        display: flex;
        gap: 10px;
        margin: 1.5rem 0;
        flex-wrap: wrap;
    }

        .hero-search input {
            padding: 0.6rem 0.8rem;
            border-radius: 8px;
            border: none;
            outline: none;
            width: 250px;
            background: #1e293b;
            color: white;
        }

    /* BUTTONS */
    .btn {
        padding: 0.5rem 1rem;
        border-radius: 8px;
        border: none;
        cursor: pointer;
        font-weight: 600;
        text-decoration: none;
        display: inline-block;
    }

    .btn-primary {
        background: #6366f1;
        color: white;
    }

        .btn-primary:hover {
            background: #4f46e5;
        }

    .btn-secondary {
        background: #887fba;
        color: white;
        border: 1px solid #334155;
    }

        .btn-secondary:hover {
            background: #334155;
        }

    .section-header {
        display: flex;
        justify-content: space-between;
        align-items: center; 
    }

    .view-all-link {
        font-size: 0.9rem;
        font-weight: 600;
        color: #818cf8;
        text-decoration: none;
        padding: 0.3rem 0.6rem;
        border-radius: 6px;
        transition: 0.2s;
    }

        .view-all-link:hover {
            background: rgba(99, 102, 241, 0.1);
            color: #a5b4fc;
        }
    /* GRID */
    .grid {
        display: grid;
        grid-template-columns: repeat(auto-fit, minmax(260px, 1fr));
        gap: 1.5rem;
        margin-top: 1.5rem;
    }

    /* CARD */
    .card {
        background: #1e293b;
        border-radius: 12px;
        overflow: hidden;
        transition: 0.3s;
    }

        .card:hover {
            transform: translateY(-4px);
        }

    .card-img {
        height: 160px;
        background: #334155;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 1.8rem;
    }

    .card-body {
        padding: 1rem;
    }

    .price {
        font-weight: bold;
        color: #22c55e;
        margin-bottom: 0.5rem;
    }

    .card-body h4 {
        margin: 0.5rem 0;
        font-size: 1rem;
    }

    .card-body p {
        font-size: 0.9rem;
        margin-bottom: 0.5rem;
    }

    /* BADGES */
    .badge {
        padding: 3px 8px;
        border-radius: 999px;
        font-size: 0.7rem;
        font-weight: 600;
        display: inline-block;
        margin-top: 4px;
    }

    .rent {
        background: rgba(34, 197, 94, 0.15);
        color: #22c55e;
    }

    .sale {
        background: rgba(245, 158, 11, 0.15);
        color: #f59e0b;
    }

    /* ROLES */
    .roles {
        margin-top: 0.5rem;
    }

        .roles span {
            background: #334155;
            padding: 4px 8px;
            border-radius: 999px;
            font-size: 0.7rem;
            margin-right: 5px;
        }

    /* RESPONSIVE */
    @@media (max-width: 600px) {
        .hero-search input

    {
        width: 100%;
    }

    }
</style>


<script>
    function search() {
        const value = document.getElementById("searchInput").value;
        window.location.href = "/Property/Browse?city=" + encodeURIComponent(value); //New%20York
    }
</script>