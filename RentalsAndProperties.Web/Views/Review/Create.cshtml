@model RentalsAndProperties.Web.ViewModels.Review.CreateReviewViewModel

@{
    ViewData["Title"] = "Write a Review";
    var isTransaction = Model.ReviewType == "Transaction";
}

<div class="review-page">

    <!-- HERO -->
    <div class="review-hero">
        <div class="review-hero-inner">
            <h1 class="review-hero-title">Write a Review</h1>
            <p class="review-hero-sub">
                @Model.PropertyTitle
                @if (isTransaction)
                {
                    <span class="review-tx-badge">Transaction Review</span>
                }
                else
                {
                    <span class="review-int-badge">Interaction Review</span>
                }
            </p>
        </div>
    </div>

    <!-- BODY -->
    <div class="review-body">

        <form asp-action="Create"
              asp-controller="Review"
              method="post"
              id="reviewForm"
              novalidate> @*novalidate is used to avoid browser validation. we can handle our own validation*@

            @Html.AntiForgeryToken()
            @Html.HiddenFor(m => m.PropertyId)
            @Html.HiddenFor(m => m.PropertyTitle)
            @Html.HiddenFor(m => m.ReviewType)
            @Html.HiddenFor(m => m.TransactionId)

            @Html.ValidationSummary(true, "", new { @class = "alert alert-error mb-3" })

            <div class="review-card">

                <!-- OVERALL RATING -->
                <div class="review-section">
                    <h2 class="review-section-title">⭐ Overall Rating</h2>
                    <p class="review-section-sub">How would you rate this property overall?</p>

                    <div class="rating-row">
                        <div class="star-rating-widget" id="ratingWidget">
                            @Html.HiddenFor(m => m.Rating, new { id = "ratingInput" })
                            @for (int i = 1; i <= 5; i++)
                            {
                                <label class="star-label" data-val="@i">★</label>
                            }
                        </div>
                        <span class="star-hint" id="starHint">Click to rate</span>
                    </div>

                    @Html.ValidationMessageFor(m => m.Rating, "", new { @class = "invalid-feedback" })
                </div>

                <!-- COMMENT -->
                <div class="review-section">
                    <h2 class="review-section-title">✍️ Your Review</h2>

                    <div class="form-group">
                        @Html.TextAreaFor(m => m.Comment, new
                        {
                            @class = "form-control review-textarea",
                                                placeholder = "Share your experience with this property...",
                                                rows = 5
                                                })
                        @Html.ValidationMessageFor(m => m.Comment, "", new { @class = "invalid-feedback" })
                        <div class="char-counter">
                            <span id="commentLen">0</span> / 2000
                        </div>
                    </div>
                </div>

                <!-- SUB RATINGS -->
                <div class="review-section">
                    <h2 class="review-section-title">📊 Detailed Ratings</h2>

                    <div class="sub-rating-grid">

                        <div class="sub-rating-item">
                            <label class="sub-rating-label">Owner Responsiveness</label>
                            <div class="mini-stars" id="ownerRespWidget">
                                @Html.HiddenFor(m => m.OwnerResponsiveness, new { id = "ownerRespInput" })
                                @for (int i = 1; i <= 5; i++)
                                {
                                    <label class="star-label" data-val="@i">★</label>
                                }
                            </div>
                        </div>

                        <div class="sub-rating-item">
                            <label class="sub-rating-label">Property Accuracy</label>
                            <div class="mini-stars" id="propAccWidget">
                                @Html.HiddenFor(m => m.PropertyAccuracy, new { id = "propAccInput" })
                                @for (int i = 1; i <= 5; i++)
                                {
                                    <label class="star-label" data-val="@i">★</label>
                                }
                            </div>
                        </div>

                    </div>
                </div>
            </div>

            <!-- SUBMIT -->
            <div class="review-submit-bar">
                <a asp-controller="Property"
                   asp-action="Details"
                   asp-route-id="@Model.PropertyId"
                   class="btn btn-secondary">
                    Cancel
                </a>
                <button type="submit" class="btn btn-primary btn-lg" id="reviewBtn">
                    ⭐ Submit Review
                </button>
            </div>

        </form>

    </div>
</div>

<style>
    .review-page {
        max-width: 700px;
        margin: auto;
        padding: 20px;
        font-family: Arial, sans-serif;
    }

    .review-hero {
        margin-bottom: 20px;
    }

    .review-hero-title {
        font-size: 24px;
        font-weight: bold;
    }

    .review-hero-sub {
        color: #555;
        font-size: 14px;
    }

    .review-tx-badge,
    .review-int-badge {
        margin-left: 8px;
        font-size: 12px;
        padding: 3px 8px;
        border-radius: 5px;
        background: #eee;
    }

    .review-card {
        border: 1px solid #ddd;
        border-radius: 6px;
        background: #fff;
    }

    .review-section {
        padding: 15px;
        border-bottom: 1px solid #eee;
    }

        .review-section:last-child {
            border-bottom: none;
        }

    .review-section-title {
        font-weight: bold;
        margin-bottom: 5px;
        font-size: 15px;
        color: black;
    }

    .review-section-sub {
        font-size: 13px;
        color: #777;
        margin-bottom: 10px;
    }

    .rating-row {
        display: flex;
        align-items: center;
    }

    .star-rating-widget,
    .mini-stars {
        display: flex;
        gap: 4px;
    }

    .star-label {
        font-size: 24px;
        color: #ccc;
        cursor: pointer;
        user-select: none;
        transition: color 0.1s;
    }

    .mini-stars .star-label {
        font-size: 20px;
    }

    .star-label.active {
        color: orange;
    }

    .star-hint {
        font-size: 12px;
        margin-left: 10px;
        color: #777;
    }

    .review-textarea {
        width: 100%;
        min-height: 100px;
        padding: 8px;
        border-radius: 4px;
        border: 1px solid #ccc;
    }

    .char-counter {
        text-align: right;
        font-size: 12px;
        color: #777;
        margin-top: 4px;
    }

    .sub-rating-grid {
        display: flex;
        flex-wrap: wrap;
        gap: 15px;
    }

    .sub-rating-item {
        flex: 1 1 200px;
        /*
            flex-grow: 1 ->Take extra space if available
            flex-shrink: 1 ->Shrink if space is not enough
            flex-basis: 200px ->Start with 200px width
        */
    }

    .sub-rating-label 
    {
        display: block;
        font-size: 13px;
        margin-bottom: 5px;
        color: black;
    }

    .invalid-feedback {
        color: red;
        font-size: 12px;
        display: block;
    }

    .alert-error {
        background: #fee2e2;
        color: #991b1b;
        padding: 10px;
        border-radius: 5px;
        margin-bottom: 10px;
    }

    .btn {
        padding: 8px 14px;
        border-radius: 4px;
        border: none;
        cursor: pointer;
        text-decoration: none;
        font-size: 14px;
    }

    .btn-primary {
        background: #2563eb;
        color: white;
    }

        .btn-primary:hover {
            background: #1d4ed8;
        }

    .btn-secondary {
        background: #e5e7eb;
        color: black;
    }

        .btn-secondary:hover {
            background: #d1d5db;
        }

    .review-submit-bar {
        margin-top: 15px;
        display: flex;
        justify-content: flex-end;
        gap: 10px;
    }
</style>

@section Scripts {
    <script>
        document.addEventListener('DOMContentLoaded', function () {

            var hints = ['', 'Poor', 'Fair', 'Good', 'Great', 'Excellent'];

            function initStars(widgetId, inputId, defaultVal) {
                var widget = document.getElementById(widgetId);
                if (!widget) return;

                var labels = widget.querySelectorAll('.star-label'); //Get all stars inside
                var input  = document.getElementById(inputId); //gets hidden input

                    if (defaultVal > 0 && parseInt(input.value) === 0) {
                       input.value = defaultVal;
                 }
                function updateStars(val) { //This controls which stars are filled
                    labels.forEach(function (lbl) {
                        lbl.classList.toggle('active', parseInt(lbl.dataset.val) <= val);
                    });
                }

                labels.forEach(function (lbl) {
                    var val = parseInt(lbl.dataset.val); //dataset is used to access custom HTML attributes

                    lbl.addEventListener('click', function () {
                        input.value = val;
                        updateStars(val);

                        var hint = document.getElementById('starHint');
                        if (hint) hint.textContent = hints[val] || '';
                    });

                    lbl.addEventListener('mouseover', function () {
                        updateStars(val);
                    });
                });

                widget.addEventListener('mouseleave', function () {
                    updateStars(parseInt(input.value) || defaultVal);
                });

                updateStars(parseInt(input.value) || defaultVal);
            }

            var textarea = document.querySelector('.review-textarea');
            var counter  = document.getElementById('commentLen');

            if (textarea && counter) {
                counter.textContent = textarea.value.length;
                textarea.addEventListener('input', function () {
                    counter.textContent = textarea.value.length;
                });
            }

            document.getElementById('reviewForm').addEventListener('submit', function (e) {
                var rating = parseInt(document.getElementById('ratingInput').value) || 0;
                if (rating < 1) {
                    e.preventDefault(); //Without preventDefault()->User clicks submit->Alert shows->Form STILL submits->Page reloads
                    alert('Please select a rating.');
                    return;
                }
                var btn = document.getElementById('reviewBtn');
                if (btn) {
                    btn.disabled = true;
                    btn.textContent = 'Submitting...';
                }
            });

            /* INIT */
            initStars('ratingWidget',    'ratingInput',    0);
            initStars('ownerRespWidget', 'ownerRespInput', 5);
            initStars('propAccWidget',   'propAccInput',   5);
        });
    </script>
}
