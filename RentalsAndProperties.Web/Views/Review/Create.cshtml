@model RentalsAndProperties.Web.ViewModels.Review.ReviewViewModel
@{
    ViewData["Title"] = "Write a Review";
    var isTransaction = Model.ReviewType == "Transaction";
}

<div class="review-page">
    <div class="review-hero">
        <div class="hero-orb orb-1" aria-hidden="true"></div>
        <div class="hero-orb orb-2" aria-hidden="true"></div>
        <div class="review-hero-inner">
            <div class="hero-badge">⭐ Share Your Experience</div>
            <h1 class="review-hero-title">Write a <span class="gradient-text">Review</span></h1>
            <p class="review-hero-sub">
                @Model.PropertyTitle
                @if (isTransaction)
                {
                    <span class="review-tx-badge">Transaction Review</span>
                }
                else
                {
                    <span class="review-int-badge">Interaction Review</span>
                }
            </p>
        </div>
    </div>

    <div class="review-body">
        <form asp-action="Create" asp-controller="Review" method="post" id="reviewForm" novalidate>
            @Html.AntiForgeryToken()

            <input type="hidden" asp-for="PropertyId" />
            <input type="hidden" asp-for="PropertyTitle" />
            <input type="hidden" asp-for="ReviewType" />
            <input type="hidden" asp-for="TransactionId" />

            @if (!ViewData.ModelState.IsValid)
            {
                <div class="alert alert-error mb-3">
                    <span>⚠</span>
                    <div>
                        @foreach (var e in ViewData.ModelState.Values.SelectMany(v => v.Errors))
                        {
                            <div>@e.ErrorMessage</div>
                        }
                    </div>
                </div>
            }

            <div class="review-card">
                <!-- Overall Rating -->
                <div class="review-section">
                    <h2 class="review-section-title">⭐ Overall Rating</h2>
                    <p class="review-section-sub">How would you rate this property overall?</p>
                    <div class="star-rating-widget" id="ratingWidget">
                        <input type="hidden" asp-for="Rating" id="ratingInput" />
                        @for (int i = 5; i >= 1; i--)
                        {
                            <label class="star-label" data-val="@i" title="@i star@(i > 1 ? "s" : "")">★</label>
                        }
                        <div class="star-hint" id="starHint">Click to rate</div>
                    </div>
                    <span asp-validation-for="Rating" class="invalid-feedback"></span>
                </div>

                <!-- Comment -->
                <div class="review-section">
                    <h2 class="review-section-title">✍️ Your Review</h2>
                    <div class="form-group">
                        <textarea asp-for="Comment" class="form-control review-textarea"
                                  placeholder="Share your experience with this property..."
                                  rows="5" required></textarea>
                        <span asp-validation-for="Comment" class="invalid-feedback"></span>
                        <div class="char-counter"><span id="commentLen">0</span> / 2000</div>
                    </div>
                </div>

                <!-- Sub-ratings -->
                <div class="review-section">
                    <h2 class="review-section-title">📊 Detailed Ratings</h2>
                    <div class="sub-rating-grid">
                        <div class="sub-rating-item">
                            <label class="sub-rating-label">Owner Responsiveness</label>
                            <div class="mini-stars" id="ownerRespWidget">
                                <input type="hidden" asp-for="OwnerResponsiveness" id="ownerRespInput" value="5" />
                                @for (int i = 5; i >= 1; i--)
                                {
                                    <label class="mini-star" data-val="@i">★</label>
                                }
                            </div>
                        </div>
                        <div class="sub-rating-item">
                            <label class="sub-rating-label">Property Accuracy</label>
                            <div class="mini-stars" id="propAccWidget">
                                <input type="hidden" asp-for="PropertyAccuracy" id="propAccInput" value="5" />
                                @for (int i = 5; i >= 1; i--)
                                {
                                    <label class="mini-star" data-val="@i">★</label>
                                }
                            </div>
                        </div>
                    </div>
                </div>

                <!-- Transaction-only extras -->
                @if (isTransaction)
                {
                    <div class="review-section tx-only-section">
                        <h2 class="review-section-title">💰 Transaction Details</h2>
                        <div class="sub-rating-grid">
                            <div class="sub-rating-item">
                                <label class="sub-rating-label">Price Satisfaction</label>
                                <div class="mini-stars" id="priceWidget">
                                    <input type="hidden" asp-for="PriceSatisfaction" id="priceInput" value="5" />
                                    @for (int i = 5; i >= 1; i--)
                                    {
                                        <label class="mini-star" data-val="@i">★</label>
                                    }
                                </div>
                            </div>
                            <div class="sub-rating-item">
                                <label class="sub-rating-label">Would You Recommend?</label>
                                <div class="recommend-options">
                                    <label class="recommend-chip selected" id="recYes">
                                        <input type="radio" name="WouldRecommend" value="true" checked hidden /> 👍 Yes
                                    </label>
                                    <label class="recommend-chip" id="recNo">
                                        <input type="radio" name="WouldRecommend" value="false" hidden /> 👎 No
                                    </label>
                                </div>
                            </div>
                        </div>
                    </div>
                }
            </div>

            <div class="review-submit-bar">
                <a href="/Property/Details/@Model.PropertyId" class="btn btn-secondary">Cancel</a>
                <button type="submit" class="btn btn-primary btn-lg" id="reviewBtn">
                    <span class="btn-text">⭐ Submit Review</span>
                    <span class="btn-spinner"></span>
                </button>
            </div>
        </form>
    </div>
</div>

@section HeadStyles {
    <style>
        .review-page {
            padding-top: 68px;
            min-height: 100vh;
        }

        .review-hero {
            position: relative;
            background: var(--gradient-hero);
            overflow: hidden;
            padding: 2.5rem 2rem;
        }

        .review-hero-inner {
            max-width: 720px;
            margin: 0 auto;
            position: relative;
            z-index: 1;
        }

        .review-hero-title {
            font-size: clamp(1.6rem,4vw,2.5rem);
            font-weight: 800;
            margin: .5rem 0;
        }

        .review-hero-sub {
            color: var(--text-secondary);
            display: flex;
            align-items: center;
            gap: .75rem;
            flex-wrap: wrap;
        }

        .review-tx-badge {
            padding: .25rem .75rem;
            background: rgba(108,99,255,.2);
            border: 1px solid rgba(108,99,255,.3);
            border-radius: 100px;
            font-size: .75rem;
            font-weight: 700;
            color: #a78bfa;
        }

        .review-int-badge {
            padding: .25rem .75rem;
            background: rgba(67,233,123,.15);
            border: 1px solid rgba(67,233,123,.3);
            border-radius: 100px;
            font-size: .75rem;
            font-weight: 700;
            color: #43e97b;
        }

        .review-body {
            max-width: 720px;
            margin: 0 auto;
            padding: 2rem;
        }

        .review-card {
            background: var(--bg-card);
            border: 1px solid var(--border-subtle);
            border-radius: var(--radius-lg);
            overflow: hidden;
            margin-bottom: 1.5rem;
        }

        .review-section {
            padding: 1.75rem 2rem;
            border-bottom: 1px solid var(--border-subtle);
        }

            .review-section:last-child {
                border-bottom: none;
            }

        .review-section-title {
            font-size: 1rem;
            font-weight: 700;
            margin-bottom: .25rem;
        }

        .review-section-sub {
            font-size: .85rem;
            color: var(--text-muted);
            margin-bottom: 1rem;
        }

        /* Main star rating */
        .star-rating-widget {
            display: flex;
            flex-direction: row-reverse;
            justify-content: flex-end;
            align-items: center;
            gap: .1rem;
            position: relative;
            margin-bottom: .5rem;
        }

        .star-label {
            font-size: 2.5rem;
            color: var(--border-subtle);
            cursor: pointer;
            transition: color .15s, transform .15s;
            line-height: 1;
        }

            .star-label:hover,
            .star-label:hover ~ .star-label {
                color: #f59e0b;
            }

            .star-label.active {
                color: #f59e0b;
            }

        .star-hint {
            font-size: .82rem;
            color: var(--text-muted);
            margin-left: .75rem;
            white-space: nowrap;
        }

        /* Sub-ratings (mini stars) */
        .sub-rating-grid {
            display: grid;
            grid-template-columns: repeat(auto-fit,minmax(200px,1fr));
            gap: 1.25rem;
        }

        .sub-rating-item {
            display: flex;
            flex-direction: column;
            gap: .5rem;
        }

        .sub-rating-label {
            font-size: .82rem;
            font-weight: 600;
            color: var(--text-secondary);
        }

        .mini-stars {
            display: flex;
            flex-direction: row-reverse;
            justify-content: flex-end;
            gap: .05rem;
        }

        .mini-star {
            font-size: 1.5rem;
            color: var(--border-subtle);
            cursor: pointer;
            transition: color .12s;
            line-height: 1;
        }

            .mini-star:hover,
            .mini-star:hover ~ .mini-star {
                color: #f59e0b;
            }

            .mini-star.active {
                color: #f59e0b;
            }

        /* Textarea */
        .review-textarea {
            width: 100%;
            min-height: 130px;
            resize: vertical;
        }

        .char-counter {
            font-size: .75rem;
            color: var(--text-muted);
            text-align: right;
            margin-top: .3rem;
        }

        /* Recommend options */
        .recommend-options {
            display: flex;
            gap: .75rem;
        }

        .recommend-chip {
            padding: .4rem 1rem;
            border-radius: 100px;
            border: 1.5px solid var(--border-subtle);
            cursor: pointer;
            font-size: .85rem;
            font-weight: 600;
            transition: all .15s;
        }

            .recommend-chip:hover {
                border-color: var(--accent-1);
            }

            .recommend-chip.selected {
                background: rgba(108,99,255,.1);
                border-color: var(--accent-1);
                color: var(--accent-1);
            }

        .tx-only-section {
            background: rgba(108,99,255,.03);
        }

        .review-submit-bar {
            display: flex;
            gap: 1rem;
            justify-content: flex-end;
            padding: .5rem 0;
        }
    </style>
}

@section Scripts {
    <script>
        document.addEventListener('DOMContentLoaded', function() {
            const hints = ['', 'Poor', 'Fair', 'Good', 'Great', 'Excellent'];

            // ── Main star rating ──────────────────────────────────────────────────────
            function initMainStars() {
                const labels  = document.querySelectorAll('.star-rating-widget .star-label');
                const input   = document.getElementById('ratingInput');
                const hint    = document.getElementById('starHint');

                labels.forEach((lbl, idx) => {
                    const val = parseInt(lbl.dataset.val);
                    lbl.addEventListener('click', () => {
                        input.value = val;
                        hint.textContent = hints[val];
                        labels.forEach(l => l.classList.toggle('active', parseInt(l.dataset.val) <= val));
                    });
                    lbl.addEventListener('mouseover', () => {
                        hint.textContent = hints[val];
                        labels.forEach(l => l.classList.toggle('active', parseInt(l.dataset.val) <= val));
                    });
                });

                const widget = document.getElementById('ratingWidget');
                widget.addEventListener('mouseleave', () => {
                    const current = parseInt(input.value) || 0;
                    labels.forEach(l => l.classList.toggle('active', parseInt(l.dataset.val) <= current));
                    hint.textContent = current ? hints[current] : 'Click to rate';
                });

                // Set initial (if default value)
                const init = parseInt(input.value) || 0;
                if (init) labels.forEach(l => l.classList.toggle('active', parseInt(l.dataset.val) <= init));
            }

            // ── Mini star ratings ─────────────────────────────────────────────────────
            function initMiniStars(widgetId, inputId, defaultVal) {
                const widget = document.getElementById(widgetId);
                if (!widget) return;
                const labels = widget.querySelectorAll('.mini-star');
                const input  = document.getElementById(inputId);
                input.value  = defaultVal;

                function setActive(val) {
                    labels.forEach(l => l.classList.toggle('active', parseInt(l.dataset.val) <= val));
                }
                setActive(defaultVal);

                labels.forEach(lbl => {
                    const v = parseInt(lbl.dataset.val);
                    lbl.addEventListener('click', () => { input.value = v; setActive(v); });
                    lbl.addEventListener('mouseover', () => setActive(v));
                });
                widget.addEventListener('mouseleave', () => setActive(parseInt(input.value) || defaultVal));
            }

            initMainStars();
            initMiniStars('ownerRespWidget', 'ownerRespInput', 5);
            initMiniStars('propAccWidget',   'propAccInput',   5);
            initMiniStars('priceWidget',     'priceInput',     5);

            // ── Recommend chips ───────────────────────────────────────────────────────
            document.querySelectorAll('.recommend-chip').forEach(chip => {
                chip.addEventListener('click', () => {
                    document.querySelectorAll('.recommend-chip').forEach(c => c.classList.remove('selected'));
                    chip.classList.add('selected');
                });
            });

            // ── Char counter ──────────────────────────────────────────────────────────
            const textarea = document.querySelector('.review-textarea');
            const counter  = document.getElementById('commentLen');
            if (textarea && counter) {
                counter.textContent = textarea.value.length;
                textarea.addEventListener('input', () => counter.textContent = textarea.value.length);
            }

            // ── Submit ────────────────────────────────────────────────────────────────
            document.getElementById('reviewForm').addEventListener('submit', function(e) {
                const rating = parseInt(document.getElementById('ratingInput').value) || 0;
                if (rating < 1) {
                    e.preventDefault();
                    Toast.error('Please select a star rating.');
                    return;
                }
                setButtonLoading(document.getElementById('reviewBtn'), true);
            });
        });
    </script>
}
